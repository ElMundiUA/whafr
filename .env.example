# --- Graph backend ---
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_DATABASE=lighthouse

# --- Anthropic (used by the Librarian agent for proposal curation) ---
ANTHROPIC_API_KEY=
LIGHTHOUSE_MODEL_MAIN=claude-sonnet-4-6
LIGHTHOUSE_MODEL_FAST=claude-haiku-4-5-20251001

# --- OpenAI (used by Graphiti for entity extraction + embeddings) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_SMALL_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1024

# --- API auth ---
# Proposal endpoint requires this single shared key.
# Retrieval (MCP + /search + /fetch) is public by default.
LIGHTHOUSE_PROPOSAL_API_KEY=

# --- Sources ---
# Path to a local folder of markdown files for the markdown connector to ingest.
LIGHTHOUSE_MARKDOWN_SOURCE=./data/sources/markdown

# --- Proposal store ---
# Local directory where proposals live as markdown files in a git repo.
LIGHTHOUSE_PROPOSALS_DIR=./data/proposals
