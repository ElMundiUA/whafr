# Lighthouse Engine — environment reference.
# Source of truth: src/lighthouse/core/config.py (Settings).
# Env var = field name uppercased. Copy to .env and fill in.

# ── Database ─────────────────────────────────────────────────────────
# REQUIRED. Postgres with the pgvector extension. With docker-compose
# this is set on the engine service already; for managed Postgres
# (Neon, RDS, …) paste the connection string here.
LIGHTHOUSE_PG_URL=postgresql://lighthouse:lighthouse@localhost:5432/lighthouse

# ── OpenAI (optional) ────────────────────────────────────────────────
# Used for chunk/query embeddings (vector retrieval), the post-hybrid
# reranker, and the relevance gate. WITHOUT a key the engine runs in
# keyword-only search mode (BM25, no vectors, no rerank).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_SMALL_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1024

# ── Anthropic (optional) ─────────────────────────────────────────────
# Used by the Librarian agent (proposal curation) and the LLM gap
# classifier. Leave empty to disable both.
ANTHROPIC_API_KEY=
LIGHTHOUSE_MODEL_MAIN=claude-sonnet-4-6
LIGHTHOUSE_MODEL_FAST=claude-haiku-4-5-20251001

# ── Auth ─────────────────────────────────────────────────────────────
# Bearer token for the admin UI (/ui) and admin API (/v1/importers,
# /v1/webhooks, /v1/analytics, …). REQUIRED in production.
LIGHTHOUSE_ADMIN_TOKEN=

# Explicit opt-out of the admin token for local development only.
# The engine refuses to expose an unauthenticated admin surface
# unless this is set to true.
LIGHTHOUSE_INSECURE_ADMIN=false

# Retrieval (/v1/search + /mcp) is public by default. Set true to
# require per-workspace API keys on every retrieval call.
LIGHTHOUSE_RETRIEVAL_AUTH_REQUIRED=false

# Fernet key encrypting importer credentials (Notion tokens, S3 keys,
# …) at rest in Postgres. Same value across all replicas. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LIGHTHOUSE_SECRETS_KEY=

# Shared key gating the proposal endpoint. Empty = no auth (local
# dev only, never on a public deployment).
LIGHTHOUSE_PROPOSAL_API_KEY=

# ── Rate limiting ────────────────────────────────────────────────────
# Per-client search rate limit. 0 disables limiting.
LIGHTHOUSE_SEARCH_RATE_LIMIT_PER_MINUTE=0

# ── Gap classifier ───────────────────────────────────────────────────
# When true, every logged search gets its hits rated for usefulness
# by Claude Haiku (off the request path); low-rated searches are
# flagged as coverage gaps. Costs one Haiku call per search.
# Requires ANTHROPIC_API_KEY. Off by default.
LIGHTHOUSE_GAP_CLASSIFIER_ENABLED=false

# ── Per-workspace S3 ingestion (optional) ────────────────────────────
# When set, each workspace gets an auto-provisioned S3 importer at
# s3://<bucket>/<workspace_id>/. Leave the secret empty to use the
# instance IAM role / boto default credential chain.
LIGHTHOUSE_WORKSPACE_S3_BUCKET=
LIGHTHOUSE_WORKSPACE_S3_ENDPOINT_URL=
LIGHTHOUSE_WORKSPACE_S3_ACCESS_ID=
LIGHTHOUSE_WORKSPACE_S3_ACCESS_SECRET=

# ── OpenRouter (optional, bench only) ────────────────────────────────
# Multi-provider gateway for the OpenAI-compatible bench harness.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Relevance gate (optional) ────────────────────────────────────────
# Cheap LLM pre-filter run on each crawled doc before paying for
# embeddings. Off by default.
RELEVANCE_GATE_ENABLED=false
RELEVANCE_GATE_MODEL=gpt-4o-mini

# ── Docling (PDF/DOCX extraction sidecar, optional) ──────────────────
# WebConnector routes PDF URLs here. Empty = skip PDFs entirely.
LIGHTHOUSE_DOCLING_URL=http://localhost:5001

# ── Sources / proposals / runner ─────────────────────────────────────
# Local markdown folder for the markdown connector.
LIGHTHOUSE_MARKDOWN_SOURCE=./data/sources/markdown

# JSONL log of URLs the sitemap connector couldn't extract.
LIGHTHOUSE_FAILED_URLS_LOG=./data/source-research/unparseable.jsonl

# Git-backed proposal store directory.
LIGHTHOUSE_PROPOSALS_DIR=./data/proposals

# Source runner: YAML config of sources + schedules, and the JSON
# last-run state file.
LIGHTHOUSE_RUNNER_CONFIG=./sources.yaml
LIGHTHOUSE_RUNNER_STATE=./data/runner-state.json
