# --- Graph backend ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_dev_password
NEO4J_DATABASE=neo4j

# --- Anthropic (used by the Librarian agent for proposal curation) ---
ANTHROPIC_API_KEY=
LIGHTHOUSE_MODEL_MAIN=claude-sonnet-4-6
LIGHTHOUSE_MODEL_FAST=claude-haiku-4-5-20251001

# --- OpenAI (used by Graphiti for entity extraction + embeddings) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_SMALL_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1024

# --- API auth ---
# Proposal endpoint requires this single shared key.
# Retrieval (MCP + /search + /fetch) is public by default.
LIGHTHOUSE_PROPOSAL_API_KEY=

# --- Sources ---
# Path to a local folder of markdown files for the markdown connector to ingest.
LIGHTHOUSE_MARKDOWN_SOURCE=./data/sources/markdown

# --- Docling (PDF extraction sidecar) ---
# WebConnector routes PDF URLs here. Empty = skip PDFs entirely.
LIGHTHOUSE_DOCLING_URL=http://localhost:5001

# --- Relevance gate (cheap LLM pre-filter) ---
# Before paying for full entity extraction, run a cheap LLM check
# on whether each crawled doc is on-topic for any role.
RELEVANCE_GATE_ENABLED=false
RELEVANCE_GATE_MODEL=gpt-4o-mini

# --- Sitemap-crawl failure log ---
# JSONL of every URL the sitemap connector couldn't extract.
LIGHTHOUSE_FAILED_URLS_LOG=./data/source-research/unparseable.jsonl

# --- Proposal store ---
# Local directory where proposals live as markdown files in a git repo.
LIGHTHOUSE_PROPOSALS_DIR=./data/proposals

# --- Source runner ---
# YAML config listing sources + schedules; JSON last-run state file.
LIGHTHOUSE_RUNNER_CONFIG=./sources.yaml
LIGHTHOUSE_RUNNER_STATE=./data/runner-state.json
