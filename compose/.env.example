# Lighthouse local stack — required + optional env.
# Copy to .env, fill values, then `docker compose up -d`.

# ─────────────────────────── Required ───────────────────────────

# Fernet master key for encrypted importer secrets. Generate ONCE,
# back it up — losing this means losing every encrypted importer
# config. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LIGHTHOUSE_SECRETS_KEY=

# Bearer token for the /v1/* admin surface. Generate with:
#   openssl rand -base64 32
# Leave EMPTY to make admin endpoints open (single-tenant in-cluster
# deploy posture). Set when exposing the API publicly.
LIGHTHOUSE_ADMIN_TOKEN=

# OpenAI API key — embeddings + chunk summarisation. Required.
OPENAI_API_KEY=

# ─────────────────────────── Optional ───────────────────────────

# Anthropic — cross-encoder rerank, librarian.
ANTHROPIC_API_KEY=

# OpenRouter — alternative LLM provider.
OPENROUTER_API_KEY=

# GitHub PAT — fallback auth for the github_repo importer when an
# instance doesn't carry its own token. Optional.
GITHUB_TOKEN=

# Postgres password (defaults to lighthouse_dev). Override for prod.
POSTGRES_PASSWORD=lighthouse_dev

# Pinned image tags. Default `latest` follows main; pin a SHA for
# reproducible production rollouts.
LIGHTHOUSE_IMAGE_TAG=latest
LIGHTHOUSE_WEB_TAG=latest
