# Astro front-end env. Copy to .env for local dev.

# Where the lighthouse retrieval API lives. In prod this is the same
# host the site is served from. For local dev point at the deployed
# API:
PUBLIC_LIGHTHOUSE_API_BASE=https://lighthouse.harborgang.com

# Auth0 (Single sign-on with Ship tenant)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://lighthouse.harborgang.com/api
AUTH0_SCOPE=openid profile email

# 32+ random bytes — used to sign our own session cookie. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# Postgres — same Neon DB as the corpus (chunks table).
LIGHTHOUSE_DATABASE_URL=

# Paddle billing (sandbox by default — flip PADDLE_ENVIRONMENT to
# production before launch).
PADDLE_CLIENT_TOKEN=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_PRO_MONTHLY=
PADDLE_PRICE_PRO_ANNUAL=
PADDLE_ENVIRONMENT=sandbox

# Admin-only — owner email allowed into /admin
ADMIN_EMAIL=denys@bodyman.io
