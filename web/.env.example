# Astro front-end env. Copy to .env for local dev.

# Where the lighthouse retrieval API lives. In prod this is the same
# host the site is served from. For local dev point at the deployed
# API:
PUBLIC_LIGHTHOUSE_API_BASE=https://lighthouse.harborgang.com

# Auth0 (Single sign-on with Ship tenant)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://lighthouse.harborgang.com/api
AUTH0_SCOPE=openid profile email

# Paddle billing (test mode by default — flip to live before launch)
PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_PUBLIC_KEY=
PADDLE_PRODUCT_PRO_MONTHLY=
PADDLE_ENV=sandbox

# Admin-only — owner email allowed into /admin
ADMIN_EMAIL=denys@bodyman.io
