---
import Site from "@/layouts/Site.astro";

export const prerender = false;

const user = Astro.locals.user;
const readerHref = user ? "/home" : "/api/auth/login?return_to=/home";
const readerLabel = user ? "You're signed in" : "Sign in";

const paddleConfig = {
  token: process.env.PADDLE_CLIENT_TOKEN ?? "",
  environment: process.env.PADDLE_ENVIRONMENT ?? "sandbox",
  prices: {
    proMonthly: process.env.PADDLE_PRICE_PRO_MONTHLY ?? "",
    proAnnual: process.env.PADDLE_PRICE_PRO_ANNUAL ?? "",
    teamMonthly: process.env.PADDLE_PRICE_TEAM_MONTHLY ?? "",
    teamAnnual: process.env.PADDLE_PRICE_TEAM_ANNUAL ?? "",
  },
  signedIn: !!user,
  user: user ? { sub: user.sub, email: user.email } : null,
  loginUrl: "/api/auth/login?return_to=/pricing",
};
---

<Site title="Lighthouse pricing — $12/mo Pro" pageHeading="Pick a tier"
      pageSubhead="Same corpus on every tier — IETF RFCs, OWASP, NIST SP-800, framework docs, methodology, post-cutoff release streams. Caps reset 00:00 UTC. Cancel anytime, prorated.">

  <!-- Single global Monthly / Annual toggle drives both Pro and Team -->
  <div class="flex justify-center my-8">
    <div class="inline-flex gap-1 rounded-full border border-white/10 bg-white/[0.03] p-1 text-xs uppercase tracking-[0.15em]">
      <button data-billing="monthly"
        class="billing-toggle px-4 py-1.5 rounded-full bg-champagne text-ink font-semibold">
        Monthly
      </button>
      <button data-billing="annual"
        class="billing-toggle px-4 py-1.5 rounded-full text-mist/60 hover:text-mist">
        Annual <span class="text-champagne/80 font-semibold">−25%</span>
      </button>
    </div>
  </div>

  <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
    <!-- Anonymous -->
    <article class="glass p-5 min-w-0">
      <p class="section-kicker mb-3">Anonymous</p>
      <p class="font-display text-3xl font-extrabold mb-1">Free</p>
      <p class="text-xs text-mist/55 italic mb-4">Kicking the tyres.</p>
      <ul class="text-sm space-y-2 text-mist/80">
        <li>30 searches / day per IP</li>
        <li>Top-10 results</li>
        <li>Links to original sources</li>
        <li>No MCP token</li>
      </ul>
      <p class="mt-5 text-xs uppercase tracking-[0.15em] text-mist/55">
        Try the search bar on <a href="/" class="text-champagne">/</a>
      </p>
    </article>

    <!-- Reader (free signed-in) -->
    <article class="glass p-5 min-w-0">
      <p class="section-kicker mb-3">Reader</p>
      <p class="font-display text-3xl font-extrabold mb-1">Free</p>
      <p class="text-xs text-mist/55 italic mb-4">Daily driver for one engineer.</p>
      <ul class="text-sm space-y-2 text-mist/80">
        <li>200 searches / day</li>
        <li>Top-15 results</li>
        <li>1 personal MCP endpoint</li>
        <li>Sort by date or relevance</li>
      </ul>
      <a href={readerHref} class="btn-secondary mt-5">
        {readerLabel}
      </a>
    </article>

    <!-- Pro -->
    <article class="glass p-5 min-w-0 border-champagne/40 ring-1 ring-champagne/40">
      <p class="section-kicker mb-3">Pro</p>
      <div class="mb-1 flex items-baseline gap-1">
        <span id="pro-price" class="font-display text-3xl font-extrabold">$12</span>
        <span id="pro-cadence" class="text-sm text-mist/55">/ month</span>
      </div>
      <p class="text-xs text-mist/55 italic mb-4">One engineer, serious about it.</p>
      <ul class="text-sm space-y-2 text-mist/80">
        <li>1,500 searches / day</li>
        <li>Top-30 results</li>
        <li>Cross-encoder rerank + summary boost</li>
        <li>One MCP token per agent, revocable</li>
        <li>Notify on changes to bookmarked sources</li>
        <li>Your queries jump rerank queue under load</li>
      </ul>
      <button id="pro-checkout" class="btn-primary mt-5 w-full justify-center">
        Start Pro
      </button>
      <p id="pro-checkout-hint" class="text-mist/55 text-xs mt-2 hidden"></p>
    </article>

    <!-- Team -->
    <article class="glass p-5 min-w-0">
      <p class="section-kicker mb-3">Team</p>
      <div class="mb-1 flex items-baseline gap-1">
        <span id="team-price" class="font-display text-3xl font-extrabold">$9</span>
        <span id="team-cadence" class="text-sm text-mist/55">/ seat / month</span>
      </div>
      <p class="text-xs text-mist/55 italic mb-3">Shared usage view, GitHub-org SSO.</p>
      <label class="block text-xs uppercase tracking-[0.15em] text-mist/55 mb-3">
        Seats
        <input id="team-seats" type="number" min="2" max="200" value="2"
          class="ml-2 w-20 !border-b !border-white/15 !text-mist text-base text-center tabular-nums" />
      </label>
      <ul class="text-sm space-y-2 text-mist/80">
        <li>Everything in Pro · 1,500/seat/day</li>
        <li>GitHub-org SSO (rolling out)</li>
        <li>Shared bookmarks + usage dashboard</li>
        <li>Org-scoped private corpus (opt-in)</li>
      </ul>
      <button id="team-checkout" class="btn-primary mt-5 w-full justify-center">
        Start team plan
      </button>
      <p id="team-checkout-hint" class="text-mist/55 text-xs mt-2 hidden"></p>
    </article>

  </section>

  <!-- Engine teaser strip (explanatory variant) -->
  <section class="mt-14 max-w-2xl mx-auto border-y border-white/5 py-6 text-center text-mist/65 text-sm leading-relaxed">
    The pricing above buys access to <strong class="text-mist/85 font-normal">our hosted corpus</strong>.
    If you want the engine instead — same retrieval stack, your own sources,
    your own hardware, Apache-2.0 — that's a different product.
    <a href="/engine" class="text-champagne hover:text-mist">See /engine →</a>
  </section>
</Site>

<script id="paddle-config" type="application/json" set:html={JSON.stringify(paddleConfig)}></script>
<script src="https://cdn.paddle.com/paddle/v2/paddle.js" is:inline></script>
<script is:inline>
(() => {
  const cfg = JSON.parse(document.getElementById("paddle-config").textContent);

  // Single global billing toggle drives both Pro and Team.
  let billing = "monthly";

  const proPrice = document.getElementById("pro-price");
  const proCadence = document.getElementById("pro-cadence");
  const proButton = document.getElementById("pro-checkout");
  const proHint = document.getElementById("pro-checkout-hint");

  const teamPrice = document.getElementById("team-price");
  const teamCadence = document.getElementById("team-cadence");
  const teamButton = document.getElementById("team-checkout");
  const teamHint = document.getElementById("team-checkout-hint");
  const teamSeats = document.getElementById("team-seats");

  function setBilling(next) {
    billing = next;
    document.querySelectorAll(".billing-toggle").forEach((b) => {
      const active = b.dataset.billing === next;
      b.classList.toggle("bg-champagne", active);
      b.classList.toggle("text-ink", active);
      b.classList.toggle("font-semibold", active);
      b.classList.toggle("text-mist/60", !active);
    });
    if (next === "annual") {
      proPrice.textContent = "$9";
      proCadence.textContent = "/ month, billed $108 / year";
      teamPrice.textContent = "$7";
      teamCadence.textContent = "/ seat / month, billed annually";
    } else {
      proPrice.textContent = "$12";
      proCadence.textContent = "/ month";
      teamPrice.textContent = "$9";
      teamCadence.textContent = "/ seat / month";
    }
  }

  document.querySelectorAll(".billing-toggle").forEach((b) => {
    b.addEventListener("click", () => setBilling(b.dataset.billing));
  });

  // ---- Checkout ----
  function fallbackClick(btn) {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      window.location.href = cfg.signedIn ? "/home" : cfg.loginUrl;
    });
  }
  if (!cfg.token || !window.Paddle) {
    fallbackClick(proButton);
    fallbackClick(teamButton);
    return;
  }
  window.Paddle.Environment.set(cfg.environment);
  window.Paddle.Initialize({ token: cfg.token });

  function openCheckout(priceId, quantity, hintEl) {
    if (!cfg.signedIn) {
      window.location.href = cfg.loginUrl;
      return;
    }
    if (!priceId) {
      hintEl.textContent = "This plan isn't fully wired yet. Contact lighthouse@harborgang.com.";
      hintEl.classList.remove("hidden");
      return;
    }
    window.Paddle.Checkout.open({
      items: [{ priceId, quantity }],
      customer: { email: cfg.user.email },
      customData: { auth0_sub: cfg.user.sub, email: cfg.user.email },
      settings: {
        displayMode: "overlay",
        theme: "dark",
        successUrl: window.location.origin + "/home?from=checkout",
      },
    });
  }

  proButton.addEventListener("click", () => {
    const priceId = billing === "annual" ? cfg.prices.proAnnual : cfg.prices.proMonthly;
    openCheckout(priceId, 1, proHint);
  });

  teamButton.addEventListener("click", () => {
    const priceId = billing === "annual" ? cfg.prices.teamAnnual : cfg.prices.teamMonthly;
    const seats = Math.max(2, Math.min(200, parseInt(teamSeats.value, 10) || 2));
    teamSeats.value = String(seats);
    openCheckout(priceId, seats, teamHint);
  });
})();
</script>
