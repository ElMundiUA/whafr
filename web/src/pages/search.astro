---
import Site from "@/layouts/Site.astro";
import SearchBar from "@/components/SearchBar.astro";
import ChunkCard from "@/components/ChunkCard.astro";
import { bumpAndCheck, clientIp, subjectFor, tierForUser, LIMITS } from "@/lib/usage";

export const prerender = false;

import { API_BASE } from "@/lib/api-base";

const q = Astro.url.searchParams.get("q")?.trim() ?? "";
const sort = Astro.url.searchParams.get("sort") === "newest" ? "newest" : "relevance";
const user = Astro.locals.user;
const tier = tierForUser(user);
// Pro gets a richer top-k by default; anon/free capped at 10.
const userMax = tier === "pro" ? 30 : 10;
const topK = Math.min(
  Math.max(parseInt(Astro.url.searchParams.get("k") || "10", 10) || 10, 1),
  userMax,
);

interface Hit {
  node_id: string;
  summary: string;
  episode_ids?: string[];
  valid_from?: string | null;
}

let hits: Hit[] = [];
let errored = false;
let rateLimited = false;
let usageRemaining: number = LIMITS[tier];
let usageCount = 0;
if (q) {
  // Rate-limit is fail-open: if the DB is unreachable (dev with a
  // stub DSN, brief Neon hiccup) we still serve the search rather
  // than blank-banner the page. Counter accuracy matters less than
  // availability.
  try {
    const subject = subjectFor(user, clientIp(Astro.request));
    const check = await bumpAndCheck(subject, LIMITS[tier]);
    usageRemaining = check.remaining;
    usageCount = check.count;
    if (!check.allowed) rateLimited = true;
  } catch (err) {
    console.warn("rate-limit check failed; allowing through", err);
  }

  if (!rateLimited) {
    const ac = new AbortController();
    const timer = setTimeout(() => ac.abort(), 5000);
    try {
      const r = await fetch(
        `${API_BASE}/search?q=${encodeURIComponent(q)}&top_k=${topK}`,
        { headers: { Accept: "application/json" }, signal: ac.signal },
      );
      if (r.ok) {
        const data = await r.json();
        hits = data.hits || [];
        if (sort === "newest") {
          // Resort client-side. Relevance ranking still picks the
          // top-k; the user sees them dated-newest-first. Hits
          // without a date fall to the bottom.
          hits = [...hits].sort((a, b) => {
            const ad = a.valid_from ? Date.parse(a.valid_from) : -Infinity;
            const bd = b.valid_from ? Date.parse(b.valid_from) : -Infinity;
            return bd - ad;
          });
        }
      } else {
        errored = true;
      }
    } catch {
      errored = true;
    } finally {
      clearTimeout(timer);
    }
  }
}

const title = q ? `${q} — Lighthouse` : "Search — Lighthouse";
---

<Site
  title={title}
 
  pageHeading={q ? `“${q}”` : "Search the lighthouse"}
  pageSubhead={q ? `${hits.length} matching dispatches` : "Cite by canonical source, not by memory."}
>
  <div class="max-w-2xl mb-6">
    <SearchBar initial={q} />
  </div>

  {q && !rateLimited && (
    <div class="flex items-center gap-3 mb-8 text-xs uppercase tracking-[0.18em] text-muted">
      <span>Sort:</span>
      <a href={`/search?q=${encodeURIComponent(q)}`}
         class={`no-underline ${sort === "relevance" ? "text-champagne" : "hover:text-mist"}`}>
        Relevance
      </a>
      <span class="opacity-30">·</span>
      <a href={`/search?q=${encodeURIComponent(q)}&sort=newest`}
         class={`no-underline ${sort === "newest" ? "text-champagne" : "hover:text-mist"}`}>
        Newest
      </a>
    </div>
  )}

  {!q && (
    <section class="text-muted text-base max-w-broadsheet">
      <p class="mb-3">
        Lighthouse is a knowledge base of canonical SDLC reference for
        AI agents — RFCs, OWASP cheat sheets, NIST SP-800, framework
        docs, methodology, and post-cutoff release streams. Each
        chunk carries a one-sentence summary plus search keywords
        produced by an enrichment worker, so the BM25 + vector +
        reranker pipeline can route a fuzzy human query to the
        canonical source.
      </p>
      <p>
        Try a real question:
        <a href="/search?q=OAuth%20PKCE%20S256">OAuth PKCE S256</a> ·
        <a href="/search?q=k8s%20readiness%20probe">k8s readiness probe</a> ·
        <a href="/search?q=RAG%20chunking%20strategies">RAG chunking strategies</a> ·
        <a href="/search?q=CRDT%20vs%20OT">CRDT vs OT</a>
      </p>
    </section>
  )}

  {q && rateLimited && (
    <p class="text-accent border-2 border-accent p-4 font-serif">
      Daily search limit reached
      ({usageCount} of {LIMITS[tier]} used as a {tier === "anon" ? "guest" : `${tier} reader`}).
      {tier === "anon" && (
        <>
          {" "}<a href="/api/auth/login?return_to=/search" class="underline">Sign in</a> for 100 / day,
          or <a href="/pricing" class="underline">upgrade to Pro</a> for 5,000 / day.
        </>
      )}
      {tier === "free" && (
        <>
          {" "}<a href="/pricing" class="underline">Upgrade to Pro</a> for 5,000 / day.
        </>
      )}
      Counter resets at 00:00 UTC.
    </p>
  )}

  {q && errored && !rateLimited && (
    <p class="text-accent border border-accent p-4">
      Couldn't reach the search backend. Try again in a moment.
    </p>
  )}

  {q && !errored && !rateLimited && (
    <p class="text-xs font-mono uppercase tracking-flag text-muted mb-4">
      {usageRemaining} of {LIMITS[tier]} {tier} searches left today
    </p>
  )}

  {q && !errored && hits.length === 0 && (
    <p class="text-muted italic">
      No dispatches matched. Try a more specific term, or fewer
      keywords. Some topics — opinion-heavy domains like estimation
      or feature prioritisation — return weak results by design.
    </p>
  )}

  {q && hits.length > 0 && (
    <section class="grid grid-cols-1 md:grid-cols-2 gap-x-10">
      {hits.map((hit, i) => (
        <div class="min-w-0">
          <ChunkCard hit={hit} rank={i + 1} />
        </div>
      ))}
    </section>
  )}
</Site>
