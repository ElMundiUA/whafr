---
import Site from "@/layouts/Site.astro";

export const prerender = false;

const EFFECTIVE = "May 18, 2026";
---

<Site title="Cookies — Lighthouse"
           pageHeading="Cookie notice"
           pageSubhead={`Effective ${EFFECTIVE}.`}>
  <article class="max-w-3xl mx-auto chunk-prose">
    <p>
      Lighthouse uses a small number of cookies, all of which are strictly
      necessary for the Service to function. We don't use analytics cookies,
      tracking pixels, or third-party advertising tags.
    </p>

    <h2>Cookies we set</h2>
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Purpose</th>
          <th>Lifetime</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>lh_session</code></td>
          <td>
            Carries a signed JWT identifying you to the server after sign-in.
            HttpOnly, Secure, SameSite=Lax.
          </td>
          <td>7 days from last refresh</td>
        </tr>
      </tbody>
    </table>

    <h2>Third-party cookies during checkout</h2>
    <p>
      When you initiate a paid subscription, Paddle.com loads its checkout
      overlay on this site. Paddle may set its own cookies in the context
      of that overlay — see{" "}
      <a href="https://www.paddle.com/legal/privacy" target="_blank"
         rel="noopener noreferrer">Paddle's privacy policy</a>{" "}
      for details. Those cookies are set by Paddle, not by us, and only
      while the checkout overlay is open.
    </p>

    <h2>Auth0 sign-in</h2>
    <p>
      When you sign in via the Auth0-hosted login page on
      <code>dev-y6o0s26t4zs2hbxv.us.auth0.com</code>, Auth0 sets its own
      session cookies on that domain. We don't read them; they exist only
      to keep you signed in on Auth0's side. After the redirect back to
      Lighthouse, our <code>lh_session</code> cookie takes over.
    </p>

    <h2>Disabling cookies</h2>
    <p>
      You can block or delete cookies via your browser settings. Blocking{" "}
      <code>lh_session</code> means you can't sign in — the rest of the
      site (anonymous search, marketing pages) still works.
    </p>

    <h2>Contact</h2>
    <p>
      Questions: <a href="mailto:hello@harborgang.com">hello@harborgang.com</a>.
    </p>
  </article>
</Site>
