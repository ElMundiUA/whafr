---
import Newspaper from "@/layouts/Newspaper.astro";

export const prerender = false;

// Section overview — one row per role recipe. The `query` field is
// what gets passed to /search when the card is clicked. Several
// titles (Embedded, Network, Mobile) are too ambiguous on their
// own — "Embedded" matches text-embedding articles, "Network"
// matches neural networks — so each section ships a more specific
// disambiguating query phrase taken from its source roster.

const sections = [
  { slug: "developer",       title: "Developer",         blurb: "Pydantic / FastAPI / SQLAlchemy / TypeScript / React",     query: "FastAPI Pydantic SQLAlchemy TypeScript React framework documentation" },
  { slug: "devops",          title: "DevOps & platform", blurb: "Kubernetes / Helm / Argo / Terraform / Docker",            query: "Kubernetes Helm Argo Terraform Docker deployment" },
  { slug: "security",        title: "Security",          blurb: "OWASP / RFCs / NIST / MITRE ATT&CK",                       query: "OWASP RFC NIST security vulnerability" },
  { slug: "ml",              title: "ML / AI",           blurb: "PyTorch / HuggingFace / LangChain / MCP",                  query: "PyTorch HuggingFace LangChain LLM model training" },
  { slug: "self-heal",       title: "Self-heal & SRE",   blurb: "OpenTelemetry / Honeycomb / Brendan Gregg / SRE Book",     query: "OpenTelemetry SRE incident observability tracing" },
  { slug: "validation",      title: "Testing",           blurb: "Playwright / Jest / Pytest / Vitest / BDD",                query: "Playwright Pytest Jest test automation BDD" },
  { slug: "network",         title: "Network",           blurb: "TLS / QUIC / HTTP/3 / OAuth / DNS RFCs",                   query: "TLS QUIC HTTP DNS OAuth protocol RFC" },
  { slug: "performance",     title: "Performance",       blurb: "Web Vitals / k6 / async-profiler / Postgres EXPLAIN",      query: "Web Vitals LCP CLS performance profiling latency" },
  { slug: "mobile",          title: "Mobile",            blurb: "React Native / Expo / Compose / SwiftUI",                  query: "React Native Expo Jetpack Compose SwiftUI iOS Android" },
  { slug: "architecture",    title: "Architecture",      blurb: "DDD / microservices / CRDT / event sourcing",              query: "domain driven design microservices CRDT event sourcing pattern" },
  { slug: "designer",        title: "Designer",          blurb: "shadcn / Tailwind / WCAG / NN/g",                          query: "shadcn Tailwind WCAG accessibility design system" },
  { slug: "reviewer",        title: "Reviewer",          blurb: "Google ENG-practices / Conventional Comments / style guides", query: "code review style guide conventional comments engineering practices" },
  { slug: "planning",        title: "Planning",          blurb: "Scrum / SAFe / Kanban / capacity math",                    query: "Scrum Kanban SAFe sprint planning agile" },
  { slug: "decomposition",   title: "Decomposition",     blurb: "WBS / INVEST / story slicing",                             query: "work breakdown structure INVEST story slicing decomposition" },
  { slug: "clarification",   title: "Clarification",     blurb: "Acceptance criteria / Gherkin / Cucumber",                 query: "acceptance criteria Gherkin Cucumber requirements" },
  { slug: "product-manager", title: "Product manager",   blurb: "Cagan / Torres / Patton / Lenny",                          query: "product management discovery roadmap Cagan Torres" },
  { slug: "data-eng",        title: "Data engineering",  blurb: "dbt / Airflow / Iceberg / Kafka / Spark",                  query: "dbt Airflow Iceberg Kafka Spark data pipeline" },
  { slug: "embedded",        title: "Embedded",          blurb: "ESP-IDF / Zephyr / FreeRTOS / PlatformIO",                 query: "ESP-IDF Zephyr FreeRTOS PlatformIO firmware microcontroller" },
  { slug: "web3",            title: "Web3",              blurb: "Solidity / Foundry / EIPs / Vitalik",                      query: "Solidity Foundry Ethereum EIP smart contract" },
  { slug: "gamedev",         title: "Gamedev",           blurb: "Unity / Unreal / Godot / Bevy",                            query: "Unity Unreal Godot Bevy game engine" },
];
---

<Newspaper section="DIRECTORY" pageHeading="Sections" pageSubhead="Every role has a curated source roster — Tier 1 mainstream + canonical standards + practitioner literature + streams.">
  <section class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-2">
    {sections.map((s) => (
      <a
        href={`/search?q=${encodeURIComponent(s.query)}`}
        class="block py-3 border-b border-rule no-underline group"
      >
        <div class="flex justify-between items-baseline">
          <h3 class="font-display font-bold text-lg group-hover:text-accent">{s.title}</h3>
          <span class="font-mono text-xs uppercase tracking-flag text-muted">→</span>
        </div>
        <p class="text-sm text-muted">{s.blurb}</p>
      </a>
    ))}
  </section>
</Newspaper>
