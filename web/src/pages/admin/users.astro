---
import Site from "@/layouts/Site.astro";
import { recentUsers } from "@/lib/admin";

export const prerender = false;

const user = Astro.locals.user;
if (!user || !user.is_admin) {
  return Astro.redirect("/api/auth/login?return_to=/admin/users");
}

let users: Awaited<ReturnType<typeof recentUsers>> = [];
let dbError: string | null = null;
try {
  users = await recentUsers(100);
} catch (err) {
  dbError = String(err);
}
---

<Site title="Users — Lighthouse Admin" pageHeading="Roll-call">
  <nav class="font-mono text-xs uppercase tracking-flag mb-6 flex gap-x-6">
    <a href="/admin">Corpus</a>
    <a href="/admin/users">Users</a>
    <a href="/admin/billing">Billing</a>
  </nav>

  {dbError && (
    <p class="text-accent border-2 border-accent p-3 font-mono text-xs mb-6">{dbError}</p>
  )}

  <table class="w-full text-sm font-serif">
    <thead>
      <tr class="text-left border-b-2 border-rule font-mono uppercase tracking-flag text-xs">
        <th class="py-2">Email</th>
        <th class="py-2 w-20">Tier</th>
        <th class="py-2 w-44">Last login</th>
        <th class="py-2 w-44">Pro until</th>
        <th class="py-2 w-32 text-right">Set</th>
      </tr>
    </thead>
    <tbody>
      {users.map((u) => (
        <tr class="border-b border-rule">
          <td class="py-1.5">{u.email}</td>
          <td class="py-1.5">
            <span class={u.tier === "pro" ? "section-flag" : "byline"}>
              {u.tier}
            </span>
          </td>
          <td class="py-1.5 text-muted">{u.last_login_at ? new Date(u.last_login_at).toISOString().slice(0, 19).replace("T", " ") : "—"}</td>
          <td class="py-1.5 text-muted">{u.pro_until ? new Date(u.pro_until).toISOString().slice(0, 10) : "—"}</td>
          <td class="py-1.5 w-32">
            <form action="/api/admin/set-tier" method="post" class="flex gap-1 items-center">
              <input type="hidden" name="user_id" value={u.id} />
              {u.tier === "pro" ? (
                <button name="tier" value="free"
                  class="text-xs uppercase tracking-[0.12em] text-mist/60 hover:text-coral"
                  title="Downgrade to free">→ Free</button>
              ) : (
                <button name="tier" value="pro"
                  class="text-xs uppercase tracking-[0.12em] text-mist/60 hover:text-champagne"
                  title="Comp to Pro (bypasses Paddle)">→ Pro</button>
              )}
            </form>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</Site>
