---
import Site from "@/layouts/Site.astro";
import { listTypes } from "@/lib/importers-api";

export const prerender = false;

const user = Astro.locals.user;
if (!user || !user.is_admin) {
  return Astro.redirect("/api/auth/login?return_to=/admin/importers/new");
}

let types: Awaited<ReturnType<typeof listTypes>> = [];
let err: string | null = null;
try {
  types = await listTypes();
} catch (e) {
  err = String(e);
}
---

<Site title="New importer — Lighthouse admin" pageHeading="New importer">
  <nav class="font-mono text-xs uppercase tracking-flag mb-6 flex gap-x-6">
    <a href="/admin/importers" class="text-champagne">← Importers</a>
  </nav>

  {err && (
    <p class="mb-6 rounded-2xl border border-coral/40 bg-coral/5 p-4 text-coral font-mono text-xs">
      {err}
    </p>
  )}

  <!-- Step indicator -->
  <ol id="stepper" class="flex items-center gap-3 text-xs uppercase tracking-[0.18em] text-mist/40 mb-6">
    <li data-step-label="pick" class="text-champagne">1 · Pick type</li>
    <li>·</li>
    <li data-step-label="auth">2 · Auth</li>
    <li>·</li>
    <li data-step-label="browse">3 · Browse</li>
    <li>·</li>
    <li data-step-label="save">4 · Save</li>
  </ol>

  <!-- Step 1: pick type -->
  <section data-step="pick">
    <ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {types.map((t) => (
        <li>
          <button data-type={t.type} data-meta={JSON.stringify(t)}
                  class="pick-type w-full text-left glass p-4 hover:border-champagne/40 transition">
            <div class="flex items-start gap-3">
              <div class="flex-1 min-w-0">
                <p class="font-display text-base font-bold text-mist mb-1">{t.display_name}</p>
                <p class="text-xs text-mist/55 leading-relaxed mb-2">{t.description}</p>
                <p class="text-[10px] font-mono text-mist/35 uppercase tracking-[0.15em]">
                  {t.type}
                  {t.secret_keys.length > 0 && ` · secrets: ${t.secret_keys.join(", ")}`}
                </p>
              </div>
              {t.supports_discovery && (
                <span class="shrink-0 text-[10px] font-bold uppercase tracking-[0.15em] text-champagne border border-champagne/40 rounded px-1.5 py-0.5">
                  wizard
                </span>
              )}
            </div>
          </button>
        </li>
      ))}
    </ul>
  </section>

  <!-- Step 2: auth (for discovery types) OR full form (for non-discovery types) -->
  <section data-step="auth" class="hidden">
    <p class="text-mist/55 text-sm mb-4" id="auth-blurb"></p>

    <form id="auth-form" class="glass p-6 space-y-5">
      <div id="auth-fields" class="space-y-5"></div>
      <div class="flex items-center justify-between pt-2">
        <button type="button" class="btn-secondary !text-sm back-to-pick">← Pick another type</button>
        <button type="submit" id="auth-next" class="btn-primary !text-sm">Browse →</button>
      </div>
      <p id="auth-error" class="text-coral text-sm hidden"></p>
    </form>
  </section>

  <!-- Step 3: browse / multi-select -->
  <section data-step="browse" class="hidden">
    <div class="flex items-center justify-between mb-4">
      <p id="browse-summary" class="text-mist/55 text-sm"></p>
      <button type="button" class="btn-ghost !text-sm back-to-auth">← Edit credentials</button>
    </div>

    <input id="filter" type="text" placeholder="Filter by name…"
           class="w-full rounded-lg border border-white/10 bg-black/30 px-3 py-2 text-mist text-sm focus:border-champagne/50 outline-none mb-3" />

    <div class="flex items-center gap-3 mb-3 text-xs text-mist/55">
      <button type="button" id="select-all" class="text-champagne hover:underline">Select all (filtered)</button>
      <span>·</span>
      <button type="button" id="select-none" class="text-champagne hover:underline">Clear</button>
      <span class="ml-auto" id="selected-count">0 selected</span>
    </div>

    <ul id="item-list" class="space-y-1 max-h-[60vh] overflow-y-auto rounded-2xl border border-white/[0.08] bg-white/[0.025] p-2"></ul>

    <div class="flex items-center justify-end gap-3 mt-4">
      <button type="button" class="btn-secondary !text-sm back-to-auth">Back</button>
      <button type="button" id="to-save" class="btn-primary !text-sm" disabled>Next →</button>
    </div>
  </section>

  <!-- Step 4: name + save -->
  <section data-step="save" class="hidden">
    <form id="save-form" class="glass p-6 space-y-5">
      <p class="text-mist/55 text-sm" id="save-summary"></p>

      <div>
        <label class="block text-xs uppercase tracking-[0.18em] text-mist/55 mb-1">Name prefix</label>
        <input name="prefix" required maxlength="100"
               placeholder="e.g. notion-engineering"
               pattern="[a-z0-9-]+"
               class="w-full rounded-lg border border-white/10 bg-black/30 px-3 py-2 text-mist text-sm font-mono focus:border-champagne/50 outline-none" />
        <p class="text-xs text-mist/45 mt-1">
          Final name = prefix + slug of the item. Recipe slug uses the same value
          and stamps every chunk this importer produces.
        </p>
      </div>

      <div>
        <label class="block text-xs uppercase tracking-[0.18em] text-mist/55 mb-1">Description (optional)</label>
        <input name="description" maxlength="500"
               class="w-full rounded-lg border border-white/10 bg-black/30 px-3 py-2 text-mist text-sm focus:border-champagne/50 outline-none" />
      </div>

      <div class="flex items-center justify-between pt-2">
        <button type="button" class="btn-secondary !text-sm back-to-browse">← Back</button>
        <button type="submit" class="btn-primary !text-sm" id="save-btn">Create importers</button>
      </div>
      <p id="save-error" class="text-coral text-sm hidden"></p>
      <p id="save-progress" class="text-mist/55 text-sm hidden"></p>
    </form>
  </section>
</Site>

<script is:inline>
(() => {
  // ---------- state ----------
  const state = {
    meta: /** @type {any} */ (null),       // ImporterType
    secrets: /** @type {Record<string,string>} */ ({}),
    config: /** @type {Record<string,any>} */ ({}),
    items: /** @type {Array<any>} */ ([]),
    selected: /** @type {Set<string>} */ (new Set()),
  };
  // Steps for which discovery doesn't fire — fall back to legacy flat form.
  // ---------- DOM ----------
  const $ = (sel) => document.querySelector(sel);
  const $steps = document.querySelectorAll("[data-step]");
  const $labels = document.querySelectorAll("[data-step-label]");

  function show(step) {
    $steps.forEach((el) => el.classList.toggle("hidden", el.dataset.step !== step));
    $labels.forEach((el) =>
      el.classList.toggle("text-champagne", el.dataset.stepLabel === step),
    );
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  // ---------- helpers ----------
  function slugify(s) {
    return s.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
  }

  // ---------- step 1: pick ----------
  document.querySelectorAll(".pick-type").forEach((btn) => {
    btn.addEventListener("click", () => {
      state.meta = JSON.parse(btn.dataset.meta);
      state.secrets = {};
      state.config = {};
      state.items = [];
      state.selected = new Set();
      renderAuth();
      show("auth");
    });
  });

  function backToPick() {
    show("pick");
  }
  document.querySelectorAll(".back-to-pick").forEach((b) =>
    b.addEventListener("click", backToPick),
  );

  // ---------- step 2: auth ----------
  function renderAuth() {
    const supports = state.meta.supports_discovery;
    const required = supports
      ? new Set(state.meta.discovery_required)
      : new Set(state.meta.config_schema.required || []);
    const slot = $("#auth-fields");
    slot.innerHTML = "";
    const props = state.meta.config_schema.properties || {};
    const secretKeys = new Set(state.meta.secret_keys);

    const keys = supports
      ? state.meta.discovery_required
      : Object.keys(props);

    $("#auth-blurb").textContent = supports
      ? `Authenticate with ${state.meta.display_name}. Browse what's available, then pick what to import.`
      : `${state.meta.display_name} doesn't list resources — fill in the full config here.`;

    $("#auth-next").textContent = supports ? "Browse →" : "Save importer";

    for (const key of keys) {
      const def = props[key];
      if (!def) continue;
      const wrap = document.createElement("div");
      const label = document.createElement("label");
      label.className = "block text-xs uppercase tracking-[0.18em] text-mist/55 mb-1";
      label.textContent = (def.title || key) + (required.has(key) ? " *" : "");
      wrap.appendChild(label);

      let inp;
      if (def.format === "textarea" || (def.type === "string" && key.includes("paths"))) {
        inp = document.createElement("textarea");
        inp.rows = 4;
        inp.className = "w-full rounded-lg border border-white/10 bg-black/30 px-3 py-2 text-mist text-sm font-mono focus:border-champagne/50 outline-none";
      } else if (def.type === "integer" || def.type === "number") {
        inp = document.createElement("input");
        inp.type = "number";
        if (def.minimum != null) inp.min = def.minimum;
        if (def.maximum != null) inp.max = def.maximum;
        if (def.type === "number") inp.step = "any";
        inp.className = "w-full rounded-lg border border-white/10 bg-black/30 px-3 py-2 text-mist text-sm font-mono focus:border-champagne/50 outline-none";
      } else if (def.type === "boolean") {
        inp = document.createElement("input");
        inp.type = "checkbox";
        inp.className = "h-4 w-4";
      } else {
        inp = document.createElement("input");
        inp.type = (def.format === "password" || secretKeys.has(key)) ? "password" : "text";
        inp.className = "w-full rounded-lg border border-white/10 bg-black/30 px-3 py-2 text-mist text-sm font-mono focus:border-champagne/50 outline-none";
      }
      inp.dataset.key = key;
      inp.dataset.kind = secretKeys.has(key) ? "secret" : "config";
      if (def.default != null) inp.value = String(def.default);
      if (required.has(key)) inp.required = true;
      wrap.appendChild(inp);
      if (def.description) {
        const help = document.createElement("p");
        help.className = "text-xs text-mist/45 mt-1";
        help.textContent = def.description;
        wrap.appendChild(help);
      }
      slot.appendChild(wrap);
    }
  }

  $("#auth-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    $("#auth-error").classList.add("hidden");
    const inputs = document.querySelectorAll("#auth-fields [data-key]");
    state.secrets = {};
    state.config = {};
    for (const inp of inputs) {
      const key = inp.dataset.key;
      let v;
      if (inp.type === "checkbox") v = inp.checked;
      else if (inp.type === "number") v = inp.value === "" ? null : Number(inp.value);
      else v = inp.value;
      if (v === "" || v == null) continue;
      if (inp.dataset.kind === "secret") state.secrets[key] = String(v);
      else state.config[key] = v;
    }

    if (state.meta.supports_discovery) {
      await runDiscovery();
    } else {
      await flatSave();
    }
  });

  // ---------- step 3: browse ----------
  async function runDiscovery() {
    const btn = $("#auth-next");
    btn.disabled = true; btn.textContent = "Browsing…";
    try {
      const r = await fetch("/api/admin/importers/discover", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          type: state.meta.type,
          config: state.config,
          secrets: state.secrets,
        }),
      });
      if (!r.ok) {
        const body = await r.text();
        $("#auth-error").textContent = `Discover failed (${r.status}): ${body.slice(0, 400)}`;
        $("#auth-error").classList.remove("hidden");
        return;
      }
      const data = await r.json();
      state.items = data.items || [];
      state.selected = new Set();
      renderItems("");
      $("#browse-summary").textContent =
        `${state.items.length} item(s) found in ${state.meta.display_name}.`;
      show("browse");
    } catch (err) {
      $("#auth-error").textContent = "Discover failed: " + String(err);
      $("#auth-error").classList.remove("hidden");
    } finally {
      btn.disabled = false; btn.textContent = "Browse →";
    }
  }

  function renderItems(filter) {
    const list = $("#item-list");
    list.innerHTML = "";
    const needle = filter.trim().toLowerCase();
    const visible = state.items.filter((it) =>
      !needle || (it.name + " " + (it.hint || "")).toLowerCase().includes(needle),
    );
    for (const it of visible) {
      const li = document.createElement("li");
      const checked = state.selected.has(it.id);
      li.className = "flex items-start gap-3 px-3 py-2 rounded-lg hover:bg-white/[0.04] cursor-pointer";
      li.innerHTML = `
        <input type="checkbox" class="mt-0.5 h-4 w-4" ${checked ? "checked" : ""} />
        <div class="flex-1 min-w-0">
          <div class="flex items-baseline gap-2">
            <span class="text-mist text-sm font-medium truncate">${escapeHtml(it.name)}</span>
            <span class="text-[10px] uppercase tracking-[0.15em] text-mist/45">${escapeHtml(it.kind)}</span>
          </div>
          ${it.hint ? `<p class="text-xs text-mist/45 truncate font-mono">${escapeHtml(it.hint)}</p>` : ""}
        </div>
      `;
      li.addEventListener("click", (e) => {
        if (e.target.tagName !== "INPUT") {
          const cb = li.querySelector("input");
          cb.checked = !cb.checked;
        }
        const cb = li.querySelector("input");
        if (cb.checked) state.selected.add(it.id);
        else state.selected.delete(it.id);
        updateSelectedCount();
      });
      list.appendChild(li);
    }
    updateSelectedCount();
  }

  function updateSelectedCount() {
    $("#selected-count").textContent = `${state.selected.size} selected`;
    $("#to-save").disabled = state.selected.size === 0;
  }

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, (c) => ({
      "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;",
    }[c]));
  }

  $("#filter").addEventListener("input", (e) => renderItems(e.target.value));
  $("#select-all").addEventListener("click", () => {
    const filter = ($("#filter").value || "").trim().toLowerCase();
    for (const it of state.items) {
      if (!filter || (it.name + " " + (it.hint || "")).toLowerCase().includes(filter)) {
        state.selected.add(it.id);
      }
    }
    renderItems($("#filter").value);
  });
  $("#select-none").addEventListener("click", () => {
    state.selected = new Set();
    renderItems($("#filter").value);
  });

  $("#to-save").addEventListener("click", () => {
    $("#save-summary").textContent =
      `${state.selected.size} ${state.meta.display_name} importer(s) will be created.`;
    show("save");
  });

  document.querySelectorAll(".back-to-auth").forEach((b) =>
    b.addEventListener("click", () => show("auth")),
  );
  document.querySelectorAll(".back-to-browse").forEach((b) =>
    b.addEventListener("click", () => show("browse")),
  );

  // ---------- step 4: save ----------
  $("#save-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    $("#save-error").classList.add("hidden");
    $("#save-progress").classList.remove("hidden");

    const fd = new FormData(e.currentTarget);
    const prefix = String(fd.get("prefix") || "").trim();
    const description = String(fd.get("description") || "").trim() || null;
    const picked = state.items.filter((it) => state.selected.has(it.id));
    const total = picked.length;
    let done = 0;
    const failures = [];
    for (const it of picked) {
      const slug = slugify(it.name) || it.id;
      const name = `${prefix}-${slug}`.slice(0, 200);
      const payload = {
        type: state.meta.type,
        name,
        recipe: name,
        description: description || `Imported from ${state.meta.display_name} (wizard)`,
        config: { ...state.config, ...(it.config_patch || {}) },
        secrets: state.secrets,
      };
      try {
        const r = await fetch("/api/admin/importers", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        if (!r.ok) {
          const txt = await r.text();
          failures.push(`${name}: ${r.status} ${txt.slice(0, 80)}`);
        }
      } catch (err) {
        failures.push(`${name}: ${String(err)}`);
      }
      done += 1;
      $("#save-progress").textContent = `Saved ${done}/${total}…`;
    }

    if (failures.length === 0) {
      window.location.href = "/admin/importers";
      return;
    }
    $("#save-progress").classList.add("hidden");
    $("#save-error").textContent =
      `${total - failures.length}/${total} saved. Failed: ` + failures.slice(0, 5).join(" · ");
    $("#save-error").classList.remove("hidden");
  });

  // ---------- non-discovery types: flat save from auth step ----------
  async function flatSave() {
    const btn = $("#auth-next");
    btn.disabled = true; btn.textContent = "Saving…";
    // For flat form, the auth step collected the WHOLE schema, so
    // state.config / state.secrets already have what we need. We
    // still need a name + recipe. Prompt with browser prompt() as
    // the simplest fallback — the legacy form had explicit fields,
    // but for now this keeps the wizard a single-codepath.
    const name = (window.prompt("Name for this importer (e.g. dev-fastapi-docs)?") || "").trim();
    if (!name) { btn.disabled = false; btn.textContent = "Save importer"; return; }
    const payload = {
      type: state.meta.type,
      name,
      recipe: name,
      description: `Created via admin wizard`,
      config: state.config,
      secrets: state.secrets,
    };
    try {
      const r = await fetch("/api/admin/importers", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!r.ok) {
        const txt = await r.text();
        $("#auth-error").textContent = `Save failed (${r.status}): ${txt.slice(0, 400)}`;
        $("#auth-error").classList.remove("hidden");
        return;
      }
      const created = await r.json();
      window.location.href = `/admin/importers/${created.id}`;
    } catch (err) {
      $("#auth-error").textContent = "Save failed: " + String(err);
      $("#auth-error").classList.remove("hidden");
    } finally {
      btn.disabled = false; btn.textContent = state.meta.supports_discovery ? "Browse →" : "Save importer";
    }
  }
})();
</script>
