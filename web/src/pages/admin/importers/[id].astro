---
import Site from "@/layouts/Site.astro";
import { getImporter, listRuns, listTypes } from "@/lib/importers-api";

export const prerender = false;

const user = Astro.locals.user;
if (!user || !user.is_admin) {
  return Astro.redirect("/api/auth/login?return_to=/admin/importers");
}

const id = Astro.params.id;
if (!id) return Astro.redirect("/admin/importers");

let importer: Awaited<ReturnType<typeof getImporter>> | null = null;
let runs: Awaited<ReturnType<typeof listRuns>> = [];
let types: Awaited<ReturnType<typeof listTypes>> = [];
let err: string | null = null;
try {
  [importer, runs, types] = await Promise.all([
    getImporter(id),
    listRuns(id),
    listTypes(),
  ]);
} catch (e) {
  err = String(e);
}

const typeMeta = importer ? types.find((t) => t.type === importer!.type) : null;

function ago(iso: string | null): string {
  if (!iso) return "—";
  const ms = Date.now() - new Date(iso).getTime();
  const m = Math.round(ms / 60_000);
  if (m < 1) return "just now";
  if (m < 60) return `${m} min ago`;
  const h = Math.round(m / 60);
  if (h < 48) return `${h} h ago`;
  return `${Math.round(h / 24)} d ago`;
}

const statusColor: Record<string, string> = {
  idle: "text-mist/60",
  queued: "text-azure",
  running: "text-champagne animate-pulse",
  error: "text-coral",
  success: "text-mist",
  cancelled: "text-mist/45",
};
---

<Site title={importer ? `${importer.name} — Lighthouse admin` : "Importer"}
      pageHeading={importer ? importer.name : "Importer"}>
  <nav class="font-mono text-xs uppercase tracking-flag mb-6 flex gap-x-6">
    <a href="/admin/importers" class="text-champagne">← Importers</a>
  </nav>

  {err && (
    <p class="mb-6 rounded-2xl border border-coral/40 bg-coral/5 p-4 text-coral font-mono text-xs">
      {err}
    </p>
  )}

  {importer && (
    <>
      <!-- Header + actions -->
      <section class="glass p-6 mb-6">
        <div class="flex flex-wrap items-start gap-5 justify-between">
          <div class="min-w-0 flex-1">
            <p class="text-xs uppercase tracking-[0.18em] text-mist/55 mb-1">{importer.type}</p>
            <p class="font-display text-xl font-bold text-mist mb-2">{importer.name}</p>
            {importer.description && <p class="text-mist/65 text-sm mb-2">{importer.description}</p>}
            <p class="text-xs font-mono text-mist/55">recipe: {importer.recipe}</p>
          </div>
          <div class="flex flex-col items-end gap-2 shrink-0">
            <p class={`text-xs uppercase tracking-[0.18em] font-semibold ${statusColor[importer.status] ?? "text-mist/60"}`}>
              {importer.status}
            </p>
            <p class="text-xs text-mist/45">last run: {ago(importer.last_run_at)}</p>
            <div class="flex gap-2 mt-1">
              <button id="run-btn" disabled={importer.status === "running"}
                      class="btn-primary !text-sm disabled:opacity-50 disabled:cursor-not-allowed">
                Run now
              </button>
              <button id="delete-btn" class="btn-secondary !text-sm">Delete</button>
            </div>
          </div>
        </div>
        {importer.last_error && (
          <pre class="mt-4 rounded-xl border border-coral/30 bg-coral/5 p-3 font-mono text-xs text-coral overflow-x-auto max-h-48">{importer.last_error}</pre>
        )}
      </section>

      <!-- Config (read-only for now — editing comes after MVP) -->
      <section class="mb-6">
        <p class="section-kicker mb-3">Config</p>
        <div class="glass p-5">
          <dl class="grid grid-cols-[10rem_1fr] gap-x-5 gap-y-2 text-sm">
            {Object.entries(importer.config).map(([k, v]) => (
              <>
                <dt class="text-mist/55 font-mono text-xs uppercase tracking-[0.12em]">{k}</dt>
                <dd class="text-mist font-mono text-xs break-all whitespace-pre-wrap">{
                  typeof v === "string" ? v : JSON.stringify(v)
                }</dd>
              </>
            ))}
            {typeMeta && typeMeta.secret_keys.length > 0 && (
              <>
                <dt class="text-mist/55 font-mono text-xs uppercase tracking-[0.12em]">secrets</dt>
                <dd class="text-mist font-mono text-xs">
                  {importer.has_secrets ? (
                    <>
                      <span class="text-champagne">●</span> set ({typeMeta.secret_keys.join(", ")})
                    </>
                  ) : (
                    <span class="text-mist/45">none</span>
                  )}
                </dd>
              </>
            )}
          </dl>
        </div>
      </section>

      <!-- Run history -->
      <section>
        <p class="section-kicker mb-3">Recent runs</p>
        {runs.length === 0 ? (
          <p class="text-mist/55 text-sm">No runs yet.</p>
        ) : (
          <ul class="space-y-2">
            {runs.map((r) => (
              <li class="glass p-4 flex items-center gap-5 text-sm">
                <p class={`text-xs uppercase tracking-[0.18em] font-semibold w-20 shrink-0 ${statusColor[r.status] ?? "text-mist/60"}`}>
                  {r.status}
                </p>
                <p class="text-mist/55 text-xs w-32 shrink-0">{ago(r.started_at)}</p>
                <p class="text-mist tabular-nums w-32 shrink-0">+{r.chunks_added} chunks</p>
                <p class="text-mist/45 text-xs flex-1 truncate">
                  {r.error_text || `triggered by ${r.triggered_by || "—"}`}
                </p>
              </li>
            ))}
          </ul>
        )}
      </section>
    </>
  )}
</Site>

<script is:inline define:vars={{ id }}>
(() => {
  const runBtn = document.getElementById("run-btn");
  const delBtn = document.getElementById("delete-btn");

  if (runBtn) {
    runBtn.addEventListener("click", async () => {
      runBtn.disabled = true;
      runBtn.textContent = "Starting…";
      try {
        const r = await fetch(`/api/admin/importers/${id}/run`, { method: "POST" });
        if (!r.ok) throw new Error(`HTTP ${r.status}: ${await r.text()}`);
        runBtn.textContent = "Running — reload to refresh";
        setTimeout(() => window.location.reload(), 1500);
      } catch (e) {
        runBtn.disabled = false;
        runBtn.textContent = "Run now";
        alert("Run failed: " + String(e));
      }
    });
  }

  if (delBtn) {
    delBtn.addEventListener("click", async () => {
      if (!confirm("Delete this importer? Run history will also go.")) return;
      try {
        const r = await fetch(`/api/admin/importers/${id}`, { method: "DELETE" });
        if (!r.ok && r.status !== 204) throw new Error(`HTTP ${r.status}: ${await r.text()}`);
        window.location.href = "/admin/importers";
      } catch (e) {
        alert("Delete failed: " + String(e));
      }
    });
  }
})();
</script>
