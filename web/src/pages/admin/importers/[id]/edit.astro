---
import Site from "@/layouts/Site.astro";
import { getImporter, listTypes } from "@/lib/importers-api";

export const prerender = false;

const user = Astro.locals.user;
if (!user || !user.is_admin) {
  return Astro.redirect("/api/auth/login?return_to=/admin/importers");
}

const id = Astro.params.id;
if (!id) return Astro.redirect("/admin/importers");

let importer: Awaited<ReturnType<typeof getImporter>> | null = null;
let types: Awaited<ReturnType<typeof listTypes>> = [];
let err: string | null = null;
try {
  [importer, types] = await Promise.all([getImporter(id), listTypes()]);
} catch (e) {
  err = String(e);
}
const typeMeta = importer ? types.find((t) => t.type === importer!.type) : null;
---

<Site title={importer ? `Edit ${importer.name}` : "Edit importer"}
      pageHeading="Edit importer">
  <nav class="font-mono text-xs uppercase tracking-flag mb-6 flex gap-x-6">
    <a href={`/admin/importers/${id}`} class="text-champagne">← Back to importer</a>
  </nav>

  {err && (
    <p class="mb-6 rounded-2xl border border-coral/40 bg-coral/5 p-4 text-coral font-mono text-xs">
      {err}
    </p>
  )}

  {importer && typeMeta && (
    <form id="edit-form" class="glass p-6 space-y-5">
      <div>
        <label class="block text-xs uppercase tracking-[0.18em] text-mist/55 mb-1">Type</label>
        <p class="font-mono text-sm text-champagne">{typeMeta.display_name} ({typeMeta.type})</p>
        <p class="text-xs text-mist/45 mt-1">Type can't be changed after create — delete + recreate if you need a different one.</p>
      </div>

      <div>
        <label class="block text-xs uppercase tracking-[0.18em] text-mist/55 mb-1">Name</label>
        <input name="name" required maxlength="200"
               value={importer.name}
               class="w-full rounded-lg border border-white/10 bg-black/30 px-3 py-2 text-mist text-sm focus:border-champagne/50 outline-none" />
      </div>

      <div>
        <label class="block text-xs uppercase tracking-[0.18em] text-mist/55 mb-1">Recipe slug</label>
        <input name="recipe" required maxlength="200"
               value={importer.recipe}
               pattern="[a-z0-9-]+"
               class="w-full rounded-lg border border-white/10 bg-black/30 px-3 py-2 text-mist text-sm font-mono focus:border-champagne/50 outline-none" />
      </div>

      <div>
        <label class="block text-xs uppercase tracking-[0.18em] text-mist/55 mb-1">Description</label>
        <input name="description" maxlength="500"
               value={importer.description ?? ""}
               class="w-full rounded-lg border border-white/10 bg-black/30 px-3 py-2 text-mist text-sm focus:border-champagne/50 outline-none" />
      </div>

      <div id="schema-slot" class="space-y-5 pt-2 border-t border-white/5"></div>

      {typeMeta.secret_keys.length > 0 && (
        <div class="pt-3 border-t border-white/5">
          <label class="block text-xs uppercase tracking-[0.18em] text-mist/55 mb-2">Secrets</label>
          <p class="text-xs text-mist/55 mb-3">
            Existing secrets are kept unless you fill in a field below
            (rotates that key) or tick "Clear all secrets". Values
            never round-trip to the browser.
          </p>
          {typeMeta.secret_keys.map((k) => (
            <div class="mb-3">
              <label class="block text-xs uppercase tracking-[0.18em] text-mist/55 mb-1">{k}</label>
              <input data-secret={k} type="password"
                     placeholder={importer.has_secrets ? "leave blank to keep current" : ""}
                     class="w-full rounded-lg border border-white/10 bg-black/30 px-3 py-2 text-mist text-sm font-mono focus:border-champagne/50 outline-none" />
            </div>
          ))}
          {importer.has_secrets && (
            <label class="flex items-center gap-2 text-xs text-mist/65 mt-2">
              <input id="clear-secrets" type="checkbox" class="h-4 w-4" />
              Clear all secrets
            </label>
          )}
        </div>
      )}

      <div class="flex items-center justify-end gap-3 pt-2">
        <a href={`/admin/importers/${id}`} class="btn-secondary !text-sm">Cancel</a>
        <button type="submit" class="btn-primary !text-sm">Save changes</button>
      </div>
      <p id="form-error" class="text-coral text-sm hidden"></p>
    </form>
  )}
</Site>

<script is:inline define:vars={{ id, importer, typeMeta }}>
(() => {
  if (!importer || !typeMeta) return;
  const $slot = document.getElementById("schema-slot");
  const $err = document.getElementById("form-error");
  const $form = document.getElementById("edit-form");
  const secretKeys = typeMeta.secret_keys;

  function render(schema) {
    const props = (schema && schema.properties) || {};
    const required = new Set((schema && schema.required) || []);
    for (const [key, def] of Object.entries(props)) {
      if (secretKeys.includes(key)) continue;   // secrets rendered separately
      const wrap = document.createElement("div");
      const label = document.createElement("label");
      label.className = "block text-xs uppercase tracking-[0.18em] text-mist/55 mb-1";
      label.textContent = (def.title || key) + (required.has(key) ? " *" : "");
      wrap.appendChild(label);

      let inp;
      if (def.format === "textarea" || (def.type === "string" && key.includes("paths"))) {
        inp = document.createElement("textarea");
        inp.rows = 4;
        inp.className = "w-full rounded-lg border border-white/10 bg-black/30 px-3 py-2 text-mist text-sm font-mono focus:border-champagne/50 outline-none";
      } else if (def.type === "integer" || def.type === "number") {
        inp = document.createElement("input");
        inp.type = "number";
        if (def.minimum != null) inp.min = def.minimum;
        if (def.maximum != null) inp.max = def.maximum;
        if (def.type === "number") inp.step = "any";
        inp.className = "w-full rounded-lg border border-white/10 bg-black/30 px-3 py-2 text-mist text-sm font-mono focus:border-champagne/50 outline-none";
      } else if (def.type === "boolean") {
        inp = document.createElement("input");
        inp.type = "checkbox";
        inp.className = "h-4 w-4";
      } else {
        inp = document.createElement("input");
        inp.type = "text";
        inp.className = "w-full rounded-lg border border-white/10 bg-black/30 px-3 py-2 text-mist text-sm font-mono focus:border-champagne/50 outline-none";
      }
      inp.name = key;
      inp.dataset.field = key;
      const cur = importer.config[key];
      if (cur !== undefined && cur !== null) {
        if (inp.type === "checkbox") inp.checked = Boolean(cur);
        else inp.value = typeof cur === "object" ? JSON.stringify(cur) : String(cur);
      }
      if (required.has(key)) inp.required = true;
      wrap.appendChild(inp);

      if (def.description) {
        const help = document.createElement("p");
        help.className = "text-xs text-mist/45 mt-1";
        help.textContent = def.description;
        wrap.appendChild(help);
      }
      $slot.appendChild(wrap);
    }
  }
  render(typeMeta.config_schema);

  $form.addEventListener("submit", async (e) => {
    e.preventDefault();
    $err.classList.add("hidden");
    const fd = new FormData($form);
    const config = {};
    for (const inp of $slot.querySelectorAll("[data-field]")) {
      const key = inp.dataset.field;
      let v;
      if (inp.type === "checkbox") v = inp.checked;
      else if (inp.type === "number") v = inp.value === "" ? null : Number(inp.value);
      else v = inp.value;
      if (v === "" || v == null) continue;
      config[key] = v;
    }

    const payload = {
      name: String(fd.get("name") || "").trim(),
      recipe: String(fd.get("recipe") || "").trim(),
      description: String(fd.get("description") || "").trim() || null,
      config,
    };

    // Secrets handling: ticked "clear" → send empty dict; otherwise
    // collect non-empty inputs (filled = rotate this key). If no
    // checkbox and nothing filled, omit `secrets` entirely so the
    // backend's keep-existing path fires.
    const clearAll = document.getElementById("clear-secrets")?.checked;
    if (clearAll) {
      payload.secrets = {};
    } else {
      const secrets = {};
      for (const inp of document.querySelectorAll("[data-secret]")) {
        if (inp.value.trim()) secrets[inp.dataset.secret] = inp.value;
      }
      if (Object.keys(secrets).length > 0) payload.secrets = secrets;
    }

    try {
      const r = await fetch(`/api/admin/importers/${id}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!r.ok) {
        const body = await r.text();
        $err.textContent = `Save failed (${r.status}): ${body.slice(0, 400)}`;
        $err.classList.remove("hidden");
        return;
      }
      window.location.href = `/admin/importers/${id}`;
    } catch (err) {
      $err.textContent = "Save failed: " + String(err);
      $err.classList.remove("hidden");
    }
  });
})();
</script>
