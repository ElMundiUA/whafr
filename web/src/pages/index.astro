---
import Newspaper from "@/layouts/Newspaper.astro";
import SearchBar from "@/components/SearchBar.astro";
import { corpusStats, recentRepos, timeAgo } from "@/lib/stats";

export const prerender = false;

const MCP_URL = "https://lighthouse.harborgang.com/mcp/";

let stats = { total_chunks: 0, total_sources: 0, total_recipes: 0 };
let recent: Awaited<ReturnType<typeof recentRepos>> = [];
try {
  [stats, recent] = await Promise.all([corpusStats(), recentRepos(8)]);
} catch {
  /* show placeholders on db hiccup */
}
---

<Newspaper>
  <section class="max-w-3xl mx-auto py-4">
    <SearchBar placeholder="Ask Lighthouse — RFC, framework, pattern…" />
    <p class="text-muted text-sm text-center mt-3 [text-wrap:balance]">
      Canonical SDLC reference for AI agents — point your MCP client at
      <code>{MCP_URL}</code>, or search above. Each result links to the
      original source.
    </p>
  </section>

  <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-10 mb-8 max-w-broadsheet mx-auto">
    <article class="glass p-4">
      <p class="byline">Indexed chunks</p>
      <p class="font-display text-3xl font-extrabold mt-1">
        {stats.total_chunks.toLocaleString()}
      </p>
    </article>
    <article class="glass p-4">
      <p class="byline">Distinct sources</p>
      <p class="font-display text-3xl font-extrabold mt-1">
        {stats.total_sources.toLocaleString()}
      </p>
    </article>
    <article class="glass p-4">
      <p class="byline">Role recipes</p>
      <p class="font-display text-3xl font-extrabold mt-1">
        {stats.total_recipes}
      </p>
    </article>
    <article class="glass p-4">
      <p class="byline">MCP endpoint</p>
      <p class="font-mono text-xs mt-1 break-all">{MCP_URL}</p>
    </article>
  </section>

  <hr class="my-6" />

  <section class="max-w-broadsheet mx-auto">
    <h3 class="font-display text-2xl mb-4">Recently indexed</h3>
    {recent.length === 0 ? (
      <p class="text-muted text-sm italic">No recent activity.</p>
    ) : (
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left border-b border-rule uppercase tracking-[0.15em] text-xs text-muted">
            <th class="py-2 pr-4">Source</th>
            <th class="py-2 px-3 w-44">Recipes</th>
            <th class="py-2 px-3 w-20 text-right">Chunks</th>
            <th class="py-2 pl-3 w-28 text-right">Last ingest</th>
          </tr>
        </thead>
        <tbody>
          {recent.map((r) => {
            const isRepo = r.repo.includes("/") && !r.repo.includes(".");
            const href = isRepo
              ? `https://github.com/${r.repo}`
              : `https://${r.repo}`;
            return (
              <tr class="border-b border-rule align-top">
                <td class="py-2 pr-4">
                  <a href={href} target="_blank" rel="noopener noreferrer"
                     class="text-mist/85 [overflow-wrap:anywhere]">
                    {r.repo}
                  </a>
                </td>
                <td class="py-2 px-3 text-xs text-champagne/85 uppercase tracking-[0.1em]">
                  {(r.recipes ?? []).slice(0, 3).join(" · ")}
                </td>
                <td class="py-2 px-3 text-right tabular-nums">{r.chunks.toLocaleString()}</td>
                <td class="py-2 pl-3 text-right text-muted text-xs">{timeAgo(r.last_ingest)}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </section>

  <hr class="my-10" />

  <aside class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-4 text-sm max-w-broadsheet mx-auto">
    <div>
      <h4 class="font-display text-xl mb-2">What is Lighthouse?</h4>
      <p class="text-muted">
        A retrieval engine over canonical SDLC reference content — RFCs,
        OWASP, NIST SP-800, framework docs, methodology, post-cutoff
        release streams. Indexed under permissive licenses; results link
        to originals.
      </p>
    </div>
    <div>
      <h4 class="font-display text-xl mb-2">For agents</h4>
      <p class="text-muted">
        Point any MCP-capable client (Claude Desktop, Cursor, the official
        CLI) at <code class="font-mono text-xs">{MCP_URL}</code>. Wire
        <code class="font-mono text-xs">search</code> and
        <code class="font-mono text-xs">fetch_source</code> into your tool
        surface. <a href="/home">Quick-start →</a>
      </p>
    </div>
    <div>
      <h4 class="font-display text-xl mb-2">For readers</h4>
      <p class="text-muted">
        Use the search above to find the canonical doc for a question. We
        surface the right paragraph and link you to the original; we don't
        try to be the publisher.
      </p>
    </div>
  </aside>
</Newspaper>
