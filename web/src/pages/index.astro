---
import Site from "@/layouts/Site.astro";
import SearchBar from "@/components/SearchBar.astro";
import ChunkCard from "@/components/ChunkCard.astro";
import CodeBlock from "@/components/CodeBlock.astro";
import { corpusStats, recentRepos, timeAgo } from "@/lib/stats";
import { API_BASE } from "@/lib/api-base";
import { bumpAndCheck, clientIp, subjectFor, tierForUser, LIMITS } from "@/lib/usage";
import { effectiveTier } from "@/lib/users";

export const prerender = false;

const MCP_URL = "https://lighthouse.harborgang.com/mcp/";

const q = Astro.url.searchParams.get("q")?.trim() ?? "";
const sort = Astro.url.searchParams.get("sort") === "newest" ? "newest" : "relevance";
const user = Astro.locals.user;
let tier = tierForUser(user);
try { tier = await effectiveTier(user); } catch {}
const userMax = tier === "pro" ? 30 : 10;
const topK = Math.min(
  Math.max(parseInt(Astro.url.searchParams.get("k") || "10", 10) || 10, 1),
  userMax,
);

interface Hit {
  node_id: string;
  summary: string;
  source?: string | null;
  episode_ids?: string[];
  valid_from?: string | null;
}

let hits: Hit[] = [];
let errored = false;
let rateLimited = false;
let usageCount = 0;
let usageRemaining = LIMITS[tier];

if (q) {
  try {
    const subject = subjectFor(user, clientIp(Astro.request));
    const check = await bumpAndCheck(subject, LIMITS[tier]);
    usageCount = check.count;
    usageRemaining = check.remaining;
    if (!check.allowed) rateLimited = true;
  } catch (err) {
    console.warn("rate-limit check failed; allowing through", err);
  }
  if (!rateLimited) {
    const ac = new AbortController();
    const timer = setTimeout(() => ac.abort(), 5000);
    try {
      const r = await fetch(
        `${API_BASE}/search?q=${encodeURIComponent(q)}&top_k=${topK}`,
        { headers: { Accept: "application/json" }, signal: ac.signal },
      );
      if (r.ok) {
        const data = await r.json();
        hits = data.hits || [];
        if (sort === "newest") {
          hits = [...hits].sort((a, b) => {
            const ad = a.valid_from ? Date.parse(a.valid_from) : -Infinity;
            const bd = b.valid_from ? Date.parse(b.valid_from) : -Infinity;
            return bd - ad;
          });
        }
      } else {
        errored = true;
      }
    } catch {
      errored = true;
    } finally {
      clearTimeout(timer);
    }
  }
}

let stats = { total_chunks: 0, total_sources: 0, total_recipes: 0 };
let recent: Awaited<ReturnType<typeof recentRepos>> = [];
if (!q) {
  try {
    [stats, recent] = await Promise.all([corpusStats(), recentRepos(8)]);
  } catch {}
}

const title = q ? `${q} — Lighthouse` : "Lighthouse — grounding layer for coding agents";

// ── MCP client setup snippets ──
const claudeCodeCmd = `claude mcp add lighthouse --transport http --url ${MCP_URL}`;

const claudeDesktopJson = JSON.stringify({
  mcpServers: {
    lighthouse: {
      type: "http",
      url: MCP_URL,
    },
  },
}, null, 2);

const cursorJson = JSON.stringify({
  mcpServers: {
    lighthouse: {
      url: MCP_URL,
    },
  },
}, null, 2);
---

<Site title={title}>
  {!q && (
    <>
      <!-- ─────────────── Hero ─────────────── -->
      <section class="relative pt-12 pb-6 text-center">
        <div class="pointer-events-none absolute inset-x-0 -top-10 -z-10 mx-auto h-[400px] w-[800px] max-w-full opacity-50"
             style="background: radial-gradient(ellipse at center, rgba(207,169,107,0.18) 0%, transparent 65%);"></div>
        <p class="section-kicker mb-4">Grounding for coding agents</p>
        <h1 class="font-display text-5xl md:text-6xl font-extrabold tracking-tight text-mist leading-[1.05] max-w-3xl mx-auto">
          Plug your agent into <span class="text-champagne">{stats.total_chunks.toLocaleString()} canonical docs.</span>
        </h1>
        <p class="mt-5 text-mist/70 text-lg max-w-2xl mx-auto leading-relaxed">
          Claude Code, Claude Desktop, Cursor, or any MCP-capable agent.
          One line of config below. Lighthouse answers retrieval queries from
          RFCs, OWASP, NIST, framework docs — cited answers, not paraphrases.
        </p>
      </section>

      <!-- ─────────────── MCP setup — the primary value ─────────────── -->
      <section id="setup" class="mt-2">
        <div class="max-w-3xl mx-auto">
          <!-- Endpoint pill -->
          <div class="rounded-2xl border border-champagne/30 bg-champagne/[0.04] p-5 flex flex-wrap items-center gap-4 justify-between">
            <div class="min-w-0">
              <p class="section-kicker mb-1">MCP endpoint</p>
              <p class="font-mono text-sm md:text-base text-mist break-all">{MCP_URL}</p>
            </div>
            <div class="text-xs text-mist/55">
              Free 200/day signed-in · 30/day anon, no card<br/>
              Pro 1,500/day — <a href="/pricing" class="text-champagne hover:text-mist">$12/mo</a>
            </div>
          </div>

          <!-- Tabs -->
          <div class="mt-6">
            <p class="section-kicker text-center mb-4">Drop this into your client</p>
            <div role="tablist" class="flex flex-wrap justify-center gap-2 mb-4">
              <button role="tab" data-tab="cc"
                class="setup-tab rounded-full px-4 py-1.5 text-sm border border-champagne/40 bg-champagne/15 text-champagne font-semibold">
                Claude Code
              </button>
              <button role="tab" data-tab="cd"
                class="setup-tab rounded-full px-4 py-1.5 text-sm border border-white/10 text-mist/65 hover:text-mist hover:border-white/20">
                Claude Desktop
              </button>
              <button role="tab" data-tab="cu"
                class="setup-tab rounded-full px-4 py-1.5 text-sm border border-white/10 text-mist/65 hover:text-mist hover:border-white/20">
                Cursor
              </button>
            </div>

            <div data-tab-pane="cc">
              <CodeBlock caption="One-line install — runs in your terminal" code={claudeCodeCmd} lang="bash" />
              <p class="text-xs text-mist/55 mt-2">
                Adds Lighthouse to the current project. Pass <code class="font-mono">--scope user</code> for a global install.
                After: restart Claude Code; <code class="font-mono">search</code> and <code class="font-mono">fetch_source</code> appear in the tool picker.
              </p>
            </div>
            <div data-tab-pane="cd" class="hidden">
              <CodeBlock caption="~/Library/Application Support/Claude/claude_desktop_config.json" code={claudeDesktopJson} lang="json" />
              <p class="text-xs text-mist/55 mt-2">
                Edit the file or create it if absent. Merge with any existing
                <code class="font-mono">mcpServers</code> block. Quit + relaunch Claude.
              </p>
            </div>
            <div data-tab-pane="cu" class="hidden">
              <CodeBlock caption="~/.cursor/mcp.json" code={cursorJson} lang="json" />
              <p class="text-xs text-mist/55 mt-2">
                Open Cursor → Settings → MCP. The Lighthouse tool shows up in the composer's tool list after a reload.
              </p>
            </div>
          </div>

          <p class="mt-4 text-xs text-mist/45 text-center">
            Don't see your client? Any MCP-capable client works. Point it at <code class="font-mono">{MCP_URL}</code>.
          </p>
        </div>
      </section>

      <!-- ─────────────── Try it now (search) ─────────────── -->
      <section class="mt-16">
        <div class="max-w-2xl mx-auto">
          <p class="section-kicker text-center mb-4">Or try a search from the browser</p>
          <SearchBar placeholder="OAuth PKCE S256, Kubernetes readiness probe, RAG chunking…" />
          <p class="mt-3 text-xs text-mist/45 text-center font-mono">
            {stats.total_chunks.toLocaleString()} chunks · {stats.total_sources.toLocaleString()} sources · {stats.total_recipes} recipes
          </p>
        </div>
      </section>
    </>
  )}

  <!-- ─────────────── Search-results mode ─────────────── -->
  {q && (
    <>
      <section class="pt-6 max-w-2xl mx-auto">
        <SearchBar initial={q} placeholder="Ask Lighthouse…" />
        {!rateLimited && !errored && (
          <div class="flex items-center justify-center gap-3 mt-4 text-xs uppercase tracking-[0.18em] text-mist/55">
            <span>Sort:</span>
            <a href={`/?q=${encodeURIComponent(q)}`}
               class={`no-underline ${sort === "relevance" ? "text-champagne" : "hover:text-mist"}`}>Relevance</a>
            <span class="opacity-30">·</span>
            <a href={`/?q=${encodeURIComponent(q)}&sort=newest`}
               class={`no-underline ${sort === "newest" ? "text-champagne" : "hover:text-mist"}`}>Newest</a>
            <span class="opacity-30">·</span>
            <span>{hits.length} hits · {usageRemaining} of {LIMITS[tier]} left today</span>
          </div>
        )}
      </section>

      {rateLimited && (
        <section class="max-w-2xl mx-auto my-8">
          <p class="rounded-2xl border-2 border-coral/40 bg-coral/5 p-5 text-coral">
            Daily search limit reached ({usageCount} of {LIMITS[tier]} as a{" "}
            {tier === "anon" ? "guest" : `${tier} reader`}).
            {tier === "anon" && (
              <> <a href="/api/auth/login?return_to=/" class="underline">Sign in</a> for 200 / day, or <a href="/pricing" class="underline">upgrade to Pro</a> for 1,500.</>
            )}
            {tier === "free" && (
              <> <a href="/pricing" class="underline">Upgrade to Pro</a> for 1,500 / day.</>
            )}
            {" "}Counter resets at 00:00 UTC.
          </p>
        </section>
      )}

      {errored && !rateLimited && (
        <section class="max-w-2xl mx-auto my-8">
          <p class="rounded-2xl border border-coral/40 bg-coral/5 p-5 text-coral">
            Couldn't reach the search backend. Try again in a moment.
          </p>
        </section>
      )}

      {!errored && !rateLimited && hits.length === 0 && (
        <section class="max-w-2xl mx-auto my-12 text-center text-mist/55">
          <p>No results for <strong class="text-mist">"{q}"</strong>. Try fewer or more specific terms.</p>
        </section>
      )}

      {hits.length > 0 && (
        <section class="grid grid-cols-1 md:grid-cols-2 gap-x-10 mt-6">
          {hits.map((hit, i) => (
            <div class="min-w-0">
              <ChunkCard hit={hit} rank={i + 1} />
            </div>
          ))}
        </section>
      )}
    </>
  )}

  <!-- ─────────────── Home-only after-hero blocks ─────────────── -->
  {!q && (
    <>
      <!-- Recently indexed -->
      <section class="mt-20">
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="font-display text-2xl font-bold">Recently indexed</h2>
          <span class="text-xs text-mist/55">live · refreshed every 2 min</span>
        </div>
        {recent.length === 0 ? (
          <p class="text-mist/55 text-sm italic">No recent activity.</p>
        ) : (
          <div class="glass overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left border-b border-white/10 uppercase tracking-[0.15em] text-xs text-mist/55">
                  <th class="py-3 px-5">Source</th>
                  <th class="py-3 px-3 w-56">Recipes</th>
                  <th class="py-3 px-3 w-20 text-right">Chunks</th>
                  <th class="py-3 px-5 w-32 text-right">Last ingest</th>
                </tr>
              </thead>
              <tbody>
                {recent.map((r) => {
                  const isRepo = r.repo.includes("/") && !r.repo.includes(".");
                  const href = isRepo
                    ? `https://github.com/${r.repo}`
                    : `https://${r.repo}`;
                  return (
                    <tr class="border-b border-white/5 last:border-b-0 align-top hover:bg-white/[0.02]">
                      <td class="py-3 px-5">
                        <a href={href} target="_blank" rel="noopener noreferrer"
                           class="text-mist/90 hover:text-champagne no-underline [overflow-wrap:anywhere]">
                          {r.repo}
                        </a>
                      </td>
                      <td class="py-3 px-3 text-xs text-champagne/85 uppercase tracking-[0.1em]">
                        {(r.recipes ?? []).slice(0, 3).join(" · ")}
                      </td>
                      <td class="py-3 px-3 text-right tabular-nums text-mist/75">{r.chunks.toLocaleString()}</td>
                      <td class="py-3 px-5 text-right text-mist/55 text-xs">{timeAgo(r.last_ingest)}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </section>

      <!-- Plans -->
      <section class="mt-16">
        <p class="section-kicker text-center mb-6">Two plans, one corpus</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <article class="glass p-6">
            <p class="font-display text-xl font-bold mb-1">Free</p>
            <p class="text-sm text-mist/55 mb-4">200/day signed in · 30/day anon</p>
            <p class="text-mist/70 text-sm leading-relaxed">
              Same corpus, same MCP endpoint, no card. Sign in with GitHub or email.
            </p>
            <a href="/api/auth/login?return_to=/home" class="inline-flex mt-5 text-champagne text-sm font-semibold hover:text-mist no-underline">Sign in →</a>
          </article>
          <article class="glass p-6 border-champagne/30 ring-1 ring-champagne/30">
            <p class="font-display text-xl font-bold mb-1">Pro <span class="text-sm font-normal text-mist/55">· $12/mo</span></p>
            <p class="text-sm text-mist/55 mb-4">1,500/day · top-30 · watch-on-update</p>
            <p class="text-mist/70 text-sm leading-relaxed">
              Lifts the cap, opens cross-encoder rerank, notifies on changes to
              bookmarked sources. $9/seat for teams.
            </p>
            <a href="/pricing" class="inline-flex mt-5 text-champagne text-sm font-semibold hover:text-mist no-underline">See pricing →</a>
          </article>
        </div>
        <p class="mt-6 text-center text-sm text-mist/55">
          Want your own knowledge layer? <strong class="text-mist/85 font-normal">Lighthouse Engine</strong> is the same retrieval stack, Apache-2.0, with your corpus instead of ours. <a href="/engine" class="text-champagne hover:text-mist">→ /engine</a>
        </p>
      </section>
    </>
  )}
</Site>

<script is:inline>
// MCP-setup tabs — vanilla; no React hydration needed.
document.querySelectorAll(".setup-tab").forEach((btn) => {
  btn.addEventListener("click", () => {
    const tab = btn.dataset.tab;
    document.querySelectorAll(".setup-tab").forEach((b) => {
      const on = b.dataset.tab === tab;
      b.classList.toggle("bg-champagne/15", on);
      b.classList.toggle("border-champagne/40", on);
      b.classList.toggle("text-champagne", on);
      b.classList.toggle("font-semibold", on);
      b.classList.toggle("border-white/10", !on);
      b.classList.toggle("text-mist/65", !on);
    });
    document.querySelectorAll("[data-tab-pane]").forEach((p) => {
      p.classList.toggle("hidden", p.dataset.tabPane !== tab);
    });
  });
});
</script>
