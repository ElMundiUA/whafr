---
import Site from "@/layouts/Site.astro";
import SearchBar from "@/components/SearchBar.astro";
import ChunkCard from "@/components/ChunkCard.astro";
import CodeBlock from "@/components/CodeBlock.astro";
import { corpusStats, recentRepos, recentEvents, timeAgo } from "@/lib/stats";
import IndexedPulse from "@/components/IndexedPulse.astro";
import { API_BASE } from "@/lib/api-base";
import { bumpAndCheck, clientIp, subjectFor, tierForUser, LIMITS } from "@/lib/usage";
import { effectiveTier } from "@/lib/users";

export const prerender = false;

const MCP_URL = "https://lighthouse.harborgang.com/mcp/";

const q = Astro.url.searchParams.get("q")?.trim() ?? "";
const sort = Astro.url.searchParams.get("sort") === "newest" ? "newest" : "relevance";
const user = Astro.locals.user;
let tier = tierForUser(user);
try { tier = await effectiveTier(user); } catch {}
const userMax = tier === "pro" ? 30 : 10;
const topK = Math.min(
  Math.max(parseInt(Astro.url.searchParams.get("k") || "10", 10) || 10, 1),
  userMax,
);

interface Hit {
  node_id: string;
  summary: string;
  source?: string | null;
  episode_ids?: string[];
  valid_from?: string | null;
}

let hits: Hit[] = [];
let errored = false;
let rateLimited = false;
let usageCount = 0;
let usageRemaining = LIMITS[tier];

if (q) {
  try {
    const subject = subjectFor(user, clientIp(Astro.request));
    const check = await bumpAndCheck(subject, LIMITS[tier]);
    usageCount = check.count;
    usageRemaining = check.remaining;
    if (!check.allowed) rateLimited = true;
  } catch (err) {
    console.warn("rate-limit check failed; allowing through", err);
  }
  if (!rateLimited) {
    const ac = new AbortController();
    const timer = setTimeout(() => ac.abort(), 5000);
    try {
      const r = await fetch(
        `${API_BASE}/search?q=${encodeURIComponent(q)}&top_k=${topK}`,
        { headers: { Accept: "application/json" }, signal: ac.signal },
      );
      if (r.ok) {
        const data = await r.json();
        hits = data.hits || [];
        if (sort === "newest") {
          hits = [...hits].sort((a, b) => {
            const ad = a.valid_from ? Date.parse(a.valid_from) : -Infinity;
            const bd = b.valid_from ? Date.parse(b.valid_from) : -Infinity;
            return bd - ad;
          });
        }
      } else {
        errored = true;
      }
    } catch {
      errored = true;
    } finally {
      clearTimeout(timer);
    }
  }
}

let stats = { total_chunks: 0, total_sources: 0, total_recipes: 0 };
let events: Awaited<ReturnType<typeof recentEvents>> = [];
if (!q) {
  try {
    [stats, events] = await Promise.all([corpusStats(), recentEvents(30)]);
  } catch {}
}

const title = q ? `${q} — Lighthouse` : "Lighthouse — grounding layer for coding agents";

// ── MCP client setup snippets ──
const claudeCodeCmd = `claude mcp add lighthouse --transport http --url ${MCP_URL}`;

const claudeDesktopJson = JSON.stringify({
  mcpServers: {
    lighthouse: {
      type: "http",
      url: MCP_URL,
    },
  },
}, null, 2);

const cursorJson = JSON.stringify({
  mcpServers: {
    lighthouse: {
      url: MCP_URL,
    },
  },
}, null, 2);

const codexToml = `[mcp_servers.lighthouse]
transport = "http"
url = "${MCP_URL}"
`;
---

<Site title={title}>
  {!q && (
    <>
      <!-- ─────────────── Hero ─────────────── -->
      <section class="relative pt-10 pb-2 text-center">
        <div class="pointer-events-none absolute inset-x-0 -top-10 -z-10 mx-auto h-[500px] w-[1100px] max-w-full opacity-40"
             style="background: radial-gradient(ellipse at center, rgba(207,169,107,0.18) 0%, transparent 65%);"></div>
        <p class="section-kicker mb-3">Grounding for coding agents</p>
        <h1 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-mist leading-[1.1] max-w-3xl mx-auto">
          {stats.total_chunks.toLocaleString()} canonical docs your agent <span class="text-champagne">can cite.</span>
        </h1>
        <p class="mt-3 text-mist/65 text-sm md:text-base max-w-xl mx-auto">
          Plug your MCP client in, or try the same retrieval from the browser.
        </p>
      </section>

      <!-- ─────────────── Live pulse ticker (horizontal, full width) ─────────────── -->
      <IndexedPulse events={events} />

      <!-- ─────────────── Search ─────────────── -->
      <section class="mt-8 max-w-2xl mx-auto text-center">
        <p class="section-kicker mb-3">Search the corpus</p>
        <SearchBar placeholder="OAuth PKCE S256, Kubernetes readiness probe, RAG chunking…" />
        <ul class="mt-4 flex flex-wrap justify-center gap-x-3 gap-y-1.5 text-sm">
          <li><a href="/?q=OAuth+2.0+PKCE+S256" class="text-champagne/85 hover:text-champagne no-underline">OAuth 2.0 PKCE S256</a></li>
          <li class="text-mist/25">·</li>
          <li><a href="/?q=Kubernetes+readiness+vs+liveness+probe" class="text-champagne/85 hover:text-champagne no-underline">k8s readiness probe</a></li>
          <li class="text-mist/25">·</li>
          <li><a href="/?q=RAG+chunking+strategies+overlap" class="text-champagne/85 hover:text-champagne no-underline">RAG chunking</a></li>
          <li class="text-mist/25">·</li>
          <li><a href="/?q=CRDT+vs+OT+collaborative+editing" class="text-champagne/85 hover:text-champagne no-underline">CRDT vs OT</a></li>
          <li class="text-mist/25">·</li>
          <li><a href="/?q=Postgres+EXPLAIN+analyze+cost" class="text-champagne/85 hover:text-champagne no-underline">Postgres EXPLAIN</a></li>
        </ul>
      </section>

      <!-- ─────────────── MCP setup (full block) ─────────────── -->
      <section class="mt-16 max-w-3xl mx-auto">
        <div class="text-center mb-5">
          <h2 class="font-display text-xl md:text-2xl font-semibold tracking-tight text-mist mb-1.5">
            One config block — any MCP client.
          </h2>
          <p class="text-mist/65 text-sm md:text-base max-w-xl mx-auto leading-relaxed">
            Same endpoint on every tier. Lighthouse appears in your tool picker
            with <code class="font-mono text-xs">search</code> and <code class="font-mono text-xs">fetch_source</code>.
          </p>
        </div>

        <!-- Endpoint pill -->
        <div class="rounded-2xl border border-white/10 bg-white/[0.025] p-4 flex flex-wrap items-center gap-3 justify-between mb-5">
          <p class="font-mono text-sm text-mist break-all">{MCP_URL}</p>
          <span class="text-xs text-mist/45">Free anon 30/day · signed-in 200/day · Pro 1,500/day</span>
        </div>

        <!-- Client tabs -->
        <div role="tablist" class="flex flex-wrap gap-2 mb-4">
          <button role="tab" data-tab="cc"
            class="setup-tab rounded-full px-4 py-1.5 text-sm border border-champagne/40 bg-champagne/15 text-champagne font-semibold">
            Claude Code
          </button>
          <button role="tab" data-tab="cd"
            class="setup-tab rounded-full px-4 py-1.5 text-sm border border-white/10 text-mist/65 hover:text-mist hover:border-white/20">
            Claude Desktop
          </button>
          <button role="tab" data-tab="cu"
            class="setup-tab rounded-full px-4 py-1.5 text-sm border border-white/10 text-mist/65 hover:text-mist hover:border-white/20">
            Cursor
          </button>
          <button role="tab" data-tab="cx"
            class="setup-tab rounded-full px-4 py-1.5 text-sm border border-white/10 text-mist/65 hover:text-mist hover:border-white/20">
            Codex CLI
          </button>
          <button role="tab" data-tab="gpt"
            class="setup-tab rounded-full px-4 py-1.5 text-sm border border-white/10 text-mist/65 hover:text-mist hover:border-white/20">
            ChatGPT
          </button>
        </div>

        <div data-tab-pane="cc">
          <CodeBlock caption="One-line install — runs in your terminal" code={claudeCodeCmd} lang="bash" />
          <p class="text-xs text-mist/55 mt-2">
            Adds Lighthouse to the current project. <code class="font-mono">--scope user</code> for global.
            Restart, and <code class="font-mono">search</code> appears in the tool picker.
          </p>
        </div>
        <div data-tab-pane="cd" class="hidden">
          <CodeBlock caption="~/Library/Application Support/Claude/claude_desktop_config.json" code={claudeDesktopJson} lang="json" />
          <p class="text-xs text-mist/55 mt-2">
            Edit or create the file; merge into any existing <code class="font-mono">mcpServers</code>. Quit + relaunch Claude Desktop.
          </p>
        </div>
        <div data-tab-pane="cu" class="hidden">
          <CodeBlock caption="~/.cursor/mcp.json" code={cursorJson} lang="json" />
          <p class="text-xs text-mist/55 mt-2">
            Settings → MCP picks it up. Lighthouse appears in the composer's tool list after a reload.
          </p>
        </div>
        <div data-tab-pane="cx" class="hidden">
          <CodeBlock caption="~/.codex/config.toml — append this block" code={codexToml} lang="toml" />
          <p class="text-xs text-mist/55 mt-2">
            Restart any <code class="font-mono">codex</code> session; <code class="font-mono">search</code> becomes available.
            <a href="https://github.com/openai/codex#mcp" target="_blank" rel="noopener" class="text-champagne hover:text-mist">Codex MCP docs ↗</a>
          </p>
        </div>
        <div data-tab-pane="gpt" class="hidden">
          <ol class="text-sm text-mist/80 space-y-1 list-decimal pl-5 leading-relaxed">
            <li>Open <a href="https://chatgpt.com" target="_blank" rel="noopener" class="text-champagne">chatgpt.com</a> (dev mode + Pro tier needed for connectors).</li>
            <li>Settings → Connectors → Create new.</li>
            <li>Name <code class="font-mono">Lighthouse</code>, paste the URL above. Auth: blank.</li>
          </ol>
          <p class="text-xs text-mist/55 mt-2">
            <a href="https://platform.openai.com/docs/mcp" target="_blank" rel="noopener" class="text-champagne hover:text-mist">OpenAI MCP docs ↗</a>
          </p>
        </div>

        <p class="mt-4 text-xs text-mist/45 text-center">
          Other clients work too — Continue · Cline · Zed · Aider · LangGraph.
        </p>
      </section>
    </>
  )}

  <!-- ─────────────── Search-results mode ─────────────── -->
  {q && (
    <>
      <section class="pt-6 max-w-2xl mx-auto">
        <SearchBar initial={q} placeholder="Ask Lighthouse…" />
        {!rateLimited && !errored && (
          <div class="flex items-center justify-center gap-3 mt-4 text-xs uppercase tracking-[0.18em] text-mist/55">
            <span>Sort:</span>
            <a href={`/?q=${encodeURIComponent(q)}`}
               class={`no-underline ${sort === "relevance" ? "text-champagne" : "hover:text-mist"}`}>Relevance</a>
            <span class="opacity-30">·</span>
            <a href={`/?q=${encodeURIComponent(q)}&sort=newest`}
               class={`no-underline ${sort === "newest" ? "text-champagne" : "hover:text-mist"}`}>Newest</a>
            <span class="opacity-30">·</span>
            <span>{hits.length} hits · {usageRemaining} of {LIMITS[tier]} left today</span>
          </div>
        )}
      </section>

      {rateLimited && (
        <section class="max-w-2xl mx-auto my-8">
          <p class="rounded-2xl border-2 border-coral/40 bg-coral/5 p-5 text-coral">
            Daily search limit reached ({usageCount} of {LIMITS[tier]} as a{" "}
            {tier === "anon" ? "guest" : `${tier} reader`}).
            {tier === "anon" && (
              <> <a href="/api/auth/login?return_to=/" class="underline">Sign in</a> for 200 / day, or <a href="/pricing" class="underline">upgrade to Pro</a> for 1,500.</>
            )}
            {tier === "free" && (
              <> <a href="/pricing" class="underline">Upgrade to Pro</a> for 1,500 / day.</>
            )}
            {" "}Counter resets at 00:00 UTC.
          </p>
        </section>
      )}

      {errored && !rateLimited && (
        <section class="max-w-2xl mx-auto my-8">
          <p class="rounded-2xl border border-coral/40 bg-coral/5 p-5 text-coral">
            Couldn't reach the search backend. Try again in a moment.
          </p>
        </section>
      )}

      {!errored && !rateLimited && hits.length === 0 && (
        <section class="max-w-2xl mx-auto my-12 text-center text-mist/55">
          <p>No results for <strong class="text-mist">"{q}"</strong>. Try fewer or more specific terms.</p>
        </section>
      )}

      {hits.length > 0 && (
        <section class="grid grid-cols-1 md:grid-cols-2 gap-x-10 mt-6">
          {hits.map((hit, i) => (
            <div class="min-w-0">
              <ChunkCard hit={hit} rank={i + 1} />
            </div>
          ))}
        </section>
      )}
    </>
  )}

  <!-- ─────────────── Home-only after-hero blocks ─────────────── -->
  {!q && (
    <>

      <!-- Plans -->
      <section class="mt-16">
        <div class="text-center mb-5">
          <h2 class="font-display text-xl md:text-2xl font-semibold tracking-tight text-mist mb-1.5">
            Two plans, one corpus.
          </h2>
          <p class="text-mist/65 text-sm md:text-base max-w-xl mx-auto leading-relaxed">
            Same retrieval on every tier. Caps reset 00:00 UTC.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-3xl mx-auto">
          <article class="glass p-6">
            <p class="section-kicker mb-2">Free</p>
            <p class="font-display text-2xl font-bold mb-1">$0</p>
            <p class="text-sm text-mist/55 mb-4">200/day signed-in · 30/day anon</p>
            <p class="text-mist/70 text-sm leading-relaxed mb-4">
              Same corpus, same MCP endpoint, no card. Sign in with GitHub or email.
            </p>
            <a href="/api/auth/login?return_to=/home" class="inline-flex text-champagne text-sm font-semibold hover:text-mist no-underline">Sign in →</a>
          </article>
          <article class="glass p-6 border-champagne/40 ring-1 ring-champagne/40">
            <p class="section-kicker mb-2">Pro</p>
            <p class="font-display text-2xl font-bold mb-1">$12<span class="text-sm font-normal text-mist/55"> /mo</span></p>
            <p class="text-sm text-mist/55 mb-4">1,500/day · top-30 · watch-on-update</p>
            <p class="text-mist/70 text-sm leading-relaxed mb-4">
              Lifts the cap, opens cross-encoder rerank, notifies on changes to
              bookmarked sources. $9/seat for teams.
            </p>
            <a href="/pricing" class="inline-flex text-champagne text-sm font-semibold hover:text-mist no-underline">See pricing →</a>
          </article>
        </div>
      </section>

      <!-- Engine block -->
      <section class="mt-16 mb-16">
        <div class="glass p-8 md:p-10 max-w-4xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-10 items-center">
            <div class="min-w-0">
              <h2 class="font-display text-xl md:text-2xl font-semibold tracking-tight mb-2">
                Run your own grounding layer.
              </h2>
              <p class="text-mist/70 text-sm md:text-base leading-relaxed mb-4">
                Want a private knowledge layer for your team — internal runbooks,
                vendor docs, private repos? <strong class="text-mist font-normal">Lighthouse Engine</strong> is
                the same retrieval stack that runs this site: ingest pipeline,
                BM25 + pgvector, cross-encoder rerank, MCP server, admin panel.
              </p>
              <p class="text-xs font-mono text-mist/55">
                Apache-2.0 · ~50 MB image · Postgres + pgvector required
              </p>
            </div>
            <div class="flex flex-col gap-2 shrink-0">
              <a href="/engine" class="btn-primary !text-sm">
                What's in the engine →
              </a>
              <a href="https://github.com/ElMundiUA/lighthouse" target="_blank" rel="noopener" class="btn-secondary !text-sm">
                View on GitHub ↗
              </a>
            </div>
          </div>
        </div>
      </section>
    </>
  )}
</Site>

<script is:inline>
// MCP-setup tabs — vanilla; no React hydration needed.
document.querySelectorAll(".setup-tab").forEach((btn) => {
  btn.addEventListener("click", () => {
    const tab = btn.dataset.tab;
    document.querySelectorAll(".setup-tab").forEach((b) => {
      const on = b.dataset.tab === tab;
      b.classList.toggle("bg-champagne/15", on);
      b.classList.toggle("border-champagne/40", on);
      b.classList.toggle("text-champagne", on);
      b.classList.toggle("font-semibold", on);
      b.classList.toggle("border-white/10", !on);
      b.classList.toggle("text-mist/65", !on);
    });
    document.querySelectorAll("[data-tab-pane]").forEach((p) => {
      p.classList.toggle("hidden", p.dataset.tabPane !== tab);
    });
  });
});
</script>
