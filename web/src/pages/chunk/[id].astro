---
import Site from "@/layouts/Site.astro";
import { prettifyChunkName, renderMarkdown } from "@/lib/chunk-display";

export const prerender = false;

import { API_BASE } from "@/lib/api-base";

const { id } = Astro.params;

interface Source {
  episode_id: string;
  name: string;
  source: string;
  content: string;
  valid_at?: string | null;
  created_at?: string | null;
}

let src: Source | null = null;
let notFound = false;
let errored = false;

if (!id) {
  notFound = true;
} else {
  try {
    const r = await fetch(`${API_BASE}/fetch_source/${id}`, {
      headers: { Accept: "application/json" },
    });
    if (r.status === 404) {
      notFound = true;
    } else if (!r.ok) {
      errored = true;
    } else {
      src = await r.json();
    }
  } catch {
    errored = true;
  }
}

const prettyName = src ? prettifyChunkName(src.name) : "";
const contentHtml = src ? renderMarkdown(src.content) : "";
const title = src ? `${prettyName} — Lighthouse` : "Chunk — Lighthouse";

// Pull origin URL out of source_description if it looks URL-shaped.
let sourceLabel = src?.source ?? "";
let sourceUrl: string | null = null;
if (sourceLabel.includes("http")) {
  const m = sourceLabel.match(/https?:\/\/\S+/);
  if (m) sourceUrl = m[0];
}

const dateStr = src?.valid_at
  ? new Date(src.valid_at).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<Site title={title} section={src ? "DISPATCH" : "ARCHIVE"}>
  {notFound && (
    <section>
      <h2 class="font-display text-3xl mb-3">Dispatch not in the archive</h2>
      <p class="text-muted">
        That chunk uuid doesn't correspond to a Lighthouse episode. It
        may have been re-ingested under a different hash. Try the
        <a href="/search">search desk</a>.
      </p>
    </section>
  )}

  {errored && (
    <p class="text-accent border border-accent p-4">
      Couldn't reach the backend. Try again in a moment.
    </p>
  )}

  {src && (
    <article class="max-w-3xl mx-auto">
      <p class="byline mb-2">
        {sourceLabel.split(":", 1)[0]}{dateStr ? ` · Filed ${dateStr}` : ""}
      </p>
      <h2 class="font-display font-extrabold text-3xl md:text-5xl leading-tight mb-3 [overflow-wrap:anywhere]">
        {prettyName}
      </h2>
      {sourceUrl && (
        <p class="text-sm mb-6 text-muted [overflow-wrap:anywhere]">
          <a href={sourceUrl} target="_blank" rel="noopener nofollow noreferrer">
            {sourceUrl} ↗
          </a>
        </p>
      )}
      <div class="chunk-prose" set:html={contentHtml}></div>
      <hr class="mt-10 mb-3" />
      <p class="text-xs uppercase tracking-[0.18em] text-muted">
        Episode <span class="normal-case tracking-normal">{src.episode_id}</span> ·
        <a href={`/search?q=${encodeURIComponent(prettyName)}`}
           class="hover:text-champagne">More like this</a>
      </p>
    </article>
  )}
</Site>
