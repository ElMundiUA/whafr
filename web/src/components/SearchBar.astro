---
// Search form — submits via GET so URLs are shareable.
// Bound to GET /search?q=…

interface Props {
  initial?: string;
  placeholder?: string;
}
const { initial = "", placeholder = "Search the lighthouse…" } = Astro.props;
---

<form action="/" method="get" class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.03] focus-within:border-champagne/40 px-4 py-2">
  <span class="text-mist/45 text-sm" aria-hidden="true">⌕</span>
  <input
    type="search"
    name="q"
    value={initial}
    placeholder={placeholder}
    autocomplete="off"
    autocapitalize="off"
    spellcheck="false"
    class="flex-1 !border-none !pb-0 bg-transparent text-base text-mist placeholder:text-mist/35"
  />
  <button type="submit" class="btn-primary !px-5 !py-2 !text-sm">
    Search
  </button>
</form>
