---
// Horizontal live-pulse ticker. Anonymised ingest events scroll
// continuously right-to-left like a stock ticker. Gradient fade on
// edges. CSS-only loop (translateX in @keyframes); pauses on
// document.visibilitychange and on hover.

import type { IndexedEvent } from "@/lib/stats";

interface Props {
  events: IndexedEvent[];
}
const { events } = Astro.props;

function fmtMinutes(n: number): string {
  if (n < 1) return "now";
  if (n < 60) return `${n}m ago`;
  const h = Math.round(n / 60);
  if (h < 24) return `${h}h ago`;
  return `${Math.round(h / 24)}d ago`;
}

// The marquee duplicates its children so the translateX from
// 0 → -50% lands seamlessly on the next copy.
const reel = events.length > 0 ? events : [];
---

<div class="relative my-8 overflow-hidden rounded-full border border-white/10 bg-white/[0.025]">
  <!-- Status badge on the left -->
  <div class="absolute left-0 top-0 bottom-0 z-10 flex items-center gap-2 px-4 bg-ink/95 backdrop-blur-sm">
    <span class="h-1.5 w-1.5 rounded-full bg-champagne animate-pulse"></span>
    <span class="text-[10px] uppercase tracking-[0.22em] text-champagne font-semibold">Live</span>
  </div>

  <!-- Gradient mask edges -->
  <div class="pointer-events-none absolute left-16 top-0 bottom-0 w-12 z-10 bg-gradient-to-r from-ink to-transparent"></div>
  <div class="pointer-events-none absolute right-0 top-0 bottom-0 w-16 z-10 bg-gradient-to-l from-ink to-transparent"></div>

  <!-- Marquee track -->
  <div class="indexed-marquee flex items-center gap-8 py-3 pl-24 whitespace-nowrap font-mono text-xs">
    {[...reel, ...reel].map((e) => (
      <span class="flex items-center gap-2 shrink-0">
        <span class="text-champagne">+ {e.chunks}</span>
        <span class="text-mist/65">chunks</span>
        <span class="text-mist/30">·</span>
        <span class="text-champagne/75 uppercase tracking-[0.1em]">{e.recipe}</span>
        <span class="text-mist/30">·</span>
        <span class="text-mist/45">{fmtMinutes(e.minutes_ago)}</span>
      </span>
    ))}
  </div>
</div>

<style>
  /* 60 s loop is gentle — fast enough to feel alive, slow enough to
     read in passing. Pauses on hover (let the visitor read) and when
     the tab is hidden (via the prefers-reduced-motion media + the
     pause class toggled by the inline script). */
  .indexed-marquee {
    animation: indexed-scroll 60s linear infinite;
    will-change: transform;
  }
  .indexed-marquee:hover {
    animation-play-state: paused;
  }
  .indexed-marquee.paused {
    animation-play-state: paused;
  }
  @keyframes indexed-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .indexed-marquee { animation: none; }
  }
</style>

<script is:inline>
(() => {
  const m = document.querySelector(".indexed-marquee");
  if (!m) return;
  function update() {
    if (document.hidden) m.classList.add("paused");
    else m.classList.remove("paused");
  }
  document.addEventListener("visibilitychange", update);
})();
</script>
