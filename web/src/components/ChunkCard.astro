---
// One search hit rendered as a newspaper article card.
//
// Shape matches the lighthouse /search endpoint:
//   { node_id, summary, episode_ids[], valid_from?, ... }

interface Props {
  hit: {
    node_id: string;
    summary: string;
    episode_ids?: string[];
    valid_from?: string | null;
    valid_until?: string | null;
    source_node_id?: string | null;
    target_node_id?: string | null;
  };
  rank?: number;            // optional ordinal (1..N) for visual weight
  variant?: "feature" | "column" | "brief";
}

const { hit, rank, variant = "column" } = Astro.props;

// Pull a section name + title from the summary header convention
// the corpus writes: "# <name>\n<body>". Front of the chunk usually
// reads like a headline.
const firstLine = hit.summary.split("\n", 2)[0] || "";
const title = firstLine.replace(/^#+\s*/, "");
const restBody = hit.summary.replace(firstLine, "").trim();

const detailHref = hit.episode_ids?.[0]
  ? `/chunk/${hit.episode_ids[0]}`
  : "#";

const dateStr = hit.valid_from
  ? new Date(hit.valid_from).toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    })
  : null;
---

<article class={`mb-8 ${variant === "feature" ? "border-b-2" : "border-b"} border-rule pb-6`}>
  {rank !== undefined && (
    <span class="kicker">#{rank}</span>
  )}
  <h3 class={
    variant === "feature"
      ? "font-display font-black text-4xl md:text-5xl leading-tight mb-2"
      : variant === "brief"
        ? "font-display font-semibold text-lg leading-snug mb-1"
        : "font-display font-bold text-2xl leading-snug mb-1.5"
  }>
    <a href={detailHref} class="no-underline hover:text-accent">{title || "Untitled chunk"}</a>
  </h3>
  {dateStr && (
    <p class="byline mb-2">Filed {dateStr}</p>
  )}
  {restBody && (
    <p class={
      variant === "brief"
        ? "text-sm leading-snug text-muted line-clamp-3"
        : "text-base leading-relaxed line-clamp-5"
    }>{restBody}</p>
  )}
  {variant !== "brief" && (
    <p class="mt-2 text-sm">
      <a href={detailHref} class="font-mono uppercase tracking-flag text-xs">Read full →</a>
    </p>
  )}
</article>
