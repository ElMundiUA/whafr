---
// One search hit rendered as a card. Title + snippet that's enough
// to identify the right doc — then a click-through to the ORIGINAL
// source (not our cached copy). Lighthouse is a finder, not a
// publisher.

import { prettifyChunkName, cleanChunkContent } from "@/lib/chunk-display";
import { parseSource } from "@/lib/source-display";

interface Props {
  hit: {
    node_id: string;
    summary: string;
    source?: string | null;          // canonical upstream id (URL / github-tree)
    episode_ids?: string[];
    valid_from?: string | null;
    valid_until?: string | null;
    source_node_id?: string | null;
    target_node_id?: string | null;
  };
  rank?: number;
  variant?: "feature" | "column" | "brief";
}

const { hit, rank, variant = "column" } = Astro.props;

const firstLine = hit.summary.split("\n", 2)[0] || "";
const title = prettifyChunkName(firstLine.replace(/^#+\s*/, "").trim());
const restBody = cleanChunkContent(hit.summary.replace(firstLine, ""));

// External link to the upstream. Falls back to "#" only when source
// is genuinely unknown (legacy graphiti hits).
const parsed = hit.source ? parseSource(hit.source) : null;
const externalHref = parsed?.href ?? null;
const sourceLabel = parsed?.display ?? "";

const dateStr = hit.valid_from
  ? new Date(hit.valid_from).toLocaleDateString("en-US", {
      month: "short", day: "numeric", year: "numeric",
    })
  : null;
---

<article class={`mb-8 ${variant === "feature" ? "border-b-2" : "border-b"} border-rule pb-6`}>
  {rank !== undefined && (
    <span class="kicker">#{rank}</span>
  )}
  <h3 class={
    `font-display [overflow-wrap:anywhere] hyphens-auto ${
      variant === "feature"
        ? "font-extrabold text-2xl md:text-3xl leading-tight mb-2 line-clamp-3"
        : variant === "brief"
          ? "font-semibold text-base leading-snug mb-1 line-clamp-2"
          : "font-bold text-xl leading-snug mb-1.5 line-clamp-3"
    }`
  }>
    {externalHref ? (
      <a href={externalHref} target="_blank" rel="noopener noreferrer"
         class="no-underline hover:text-champagne">{title || "Untitled"}</a>
    ) : (
      <span>{title || "Untitled"}</span>
    )}
  </h3>
  {sourceLabel && (
    <p class="text-xs text-muted [overflow-wrap:anywhere] mb-1.5">{sourceLabel}</p>
  )}
  {dateStr && (
    <p class="byline mb-2">Filed {dateStr}</p>
  )}
  {restBody && (
    <p class={
      variant === "brief"
        ? "text-sm leading-snug text-muted line-clamp-2"
        : "text-sm leading-relaxed text-muted line-clamp-3"
    }>{restBody}</p>
  )}
  {variant !== "brief" && externalHref && (
    <p class="mt-3 text-sm">
      <a href={externalHref} target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-1 text-champagne text-xs font-semibold uppercase tracking-[0.12em] no-underline hover:text-mist">
        Read at source <span aria-hidden="true">↗</span>
      </a>
    </p>
  )}
</article>
