---
// One search hit rendered as a newspaper article card.
//
// Shape matches the lighthouse /search endpoint:
//   { node_id, summary, episode_ids[], valid_from?, ... }

interface Props {
  hit: {
    node_id: string;
    summary: string;
    episode_ids?: string[];
    valid_from?: string | null;
    valid_until?: string | null;
    source_node_id?: string | null;
    target_node_id?: string | null;
  };
  rank?: number;            // optional ordinal (1..N) for visual weight
  variant?: "feature" | "column" | "brief";
}

const { hit, rank, variant = "column" } = Astro.props;

import { prettifyChunkName, cleanChunkContent } from "@/lib/chunk-display";

// Headline = first markdown H1 line. Body teaser = remainder, with
// YAML / shortcodes stripped so the card preview reads as prose
// rather than ingest scaffolding.
const firstLine = hit.summary.split("\n", 2)[0] || "";
const title = prettifyChunkName(firstLine.replace(/^#+\s*/, "").trim());
const restBody = cleanChunkContent(hit.summary.replace(firstLine, ""));

const detailHref = hit.episode_ids?.[0]
  ? `/chunk/${hit.episode_ids[0]}`
  : "#";

const dateStr = hit.valid_from
  ? new Date(hit.valid_from).toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    })
  : null;
---

<article class={`mb-8 ${variant === "feature" ? "border-b-2" : "border-b"} border-rule pb-6`}>
  {rank !== undefined && (
    <span class="kicker">#{rank}</span>
  )}
  <h3 class={
    `font-display [overflow-wrap:anywhere] hyphens-auto ${
      variant === "feature"
        ? "font-extrabold text-3xl md:text-4xl leading-tight mb-2 line-clamp-3"
        : variant === "brief"
          ? "font-semibold text-base leading-snug mb-1 line-clamp-2"
          : "font-bold text-xl leading-snug mb-1.5 line-clamp-3"
    }`
  }>
    <a href={detailHref} class="no-underline hover:text-champagne">{title || "Untitled chunk"}</a>
  </h3>
  {dateStr && (
    <p class="byline mb-2">Filed {dateStr}</p>
  )}
  {restBody && (
    <p class={
      variant === "brief"
        ? "text-sm leading-snug text-muted line-clamp-3"
        : "text-base leading-relaxed line-clamp-5"
    }>{restBody}</p>
  )}
  {variant !== "brief" && (
    <p class="mt-3 text-sm">
      <a href={detailHref}
         class="inline-flex items-center gap-1 text-champagne text-xs font-semibold uppercase tracking-[0.12em] no-underline hover:text-mist">
        Read full <span aria-hidden="true">→</span>
      </a>
    </p>
  )}
</article>
