---
// Code block with a copy button. Click → copies the inner text to
// clipboard, flashes "Copied". One Astro island per page is enough;
// the script is a single small handler attached on DOM ready.

interface Props {
  code: string;
  lang?: string;
  caption?: string;
}
const { code, lang, caption } = Astro.props;
---

<div class="copy-block relative">
  {caption && (
    <p class="text-xs text-mist/55 mb-1.5 font-mono">{caption}</p>
  )}
  <button type="button"
    class="copy-btn absolute top-3 right-3 rounded-md border border-white/10 bg-ink/60 backdrop-blur px-2.5 py-1 text-xs text-mist/65 hover:text-champagne hover:border-champagne/40 transition">
    Copy
  </button>
  <pre class="bg-black/40 border border-white/10 rounded-xl p-4 pr-16 overflow-x-auto text-sm leading-relaxed text-mist/90 font-mono"><code data-lang={lang}>{code}</code></pre>
</div>

<script is:inline>
document.querySelectorAll(".copy-block").forEach((block) => {
  const btn = block.querySelector(".copy-btn");
  const code = block.querySelector("code");
  if (!btn || !code) return;
  btn.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(code.textContent ?? "");
      const orig = btn.textContent;
      btn.textContent = "Copied";
      btn.classList.add("text-champagne", "border-champagne/40");
      setTimeout(() => {
        btn.textContent = orig;
        btn.classList.remove("text-champagne", "border-champagne/40");
      }, 1500);
    } catch (err) {
      console.warn("clipboard failed", err);
    }
  });
});
</script>
