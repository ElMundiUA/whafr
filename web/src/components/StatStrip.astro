---
// Hero stat strip — three big numbers in Ship's StatCard pattern:
// huge display number in a brand accent, uppercase kicker, one-line
// body. Used under the home hero to reinforce the headline figure.

interface Stat {
  value: string;
  unit?: string;
  label: string;
  body: string;
  accent: "aqua" | "lilac" | "sun";
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;

const ACCENT_TEXT: Record<Stat["accent"], string> = {
  aqua: "text-champagne",
  lilac: "text-lilac",
  sun: "text-sun",
};

const ACCENT_BORDER: Record<Stat["accent"], string> = {
  aqua: "border-champagne/25",
  lilac: "border-lilac/25",
  sun: "border-sun/25",
};
---

<section class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-5xl mx-auto">
  {stats.map((s) => (
    <div class={`flex h-full flex-col rounded-2xl border ${ACCENT_BORDER[s.accent]} bg-gradient-to-br from-white/[0.04] via-white/[0.015] to-transparent p-6 shadow-card`}>
      <div class="flex items-baseline gap-1">
        <p class={`font-display text-[3rem] sm:text-[3.5rem] font-bold leading-none tabular-nums ${ACCENT_TEXT[s.accent]}`}>
          {s.value}
        </p>
        {s.unit && (
          <p class={`font-display text-2xl sm:text-3xl font-bold ${ACCENT_TEXT[s.accent]}`}>{s.unit}</p>
        )}
      </div>
      <p class="font-display mt-3 text-xs font-bold uppercase tracking-[0.18em] text-mist/85">
        {s.label}
      </p>
      <p class="mt-2 text-xs leading-relaxed text-mist/55">{s.body}</p>
    </div>
  ))}
</section>
