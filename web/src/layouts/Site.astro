---
// Standard Harbor Gang layout — replaces Newspaper.astro for non-
// archival pages. Compact sticky navbar with backdrop-blur, generous
// whitespace, single Champagne accent, no double-rule borders or
// section flags.

import "@/styles/global.css";
import {
  LIMITS, tierForUser, subjectFor, currentUsage, clientIp,
} from "@/lib/usage";
import { effectiveTier } from "@/lib/users";

interface Props {
  title?: string;
  description?: string;
  pageHeading?: string;
  pageSubhead?: string;
  fullBleed?: boolean;       // skip the default centered container
}

const {
  title = "Lighthouse — Knowledge for AI Agents",
  description = "A knowledge base of canonical SDLC reference for AI agents — RFCs, OWASP, framework docs, methodology, post-cutoff streams.",
  pageHeading,
  pageSubhead,
  fullBleed = false,
} = Astro.props;

const user = Astro.locals.user;
const currentPath = Astro.url.pathname + Astro.url.search;

// Resolve tier from the DB on every request (with 30s in-process
// cache) so admin tier-toggle effect is visible without re-login.
// Cookie-tier is stale for cap-comped users.
let tier = tierForUser(user);
try {
  const dbTier = await effectiveTier(user);
  tier = dbTier;
} catch {
  /* keep cookie-tier */
}
const limit = LIMITS[tier];
let usedToday = 0;
try {
  usedToday = await currentUsage(subjectFor(user, clientIp(Astro.request)));
} catch {
  /* keep 0 */
}

const nav = [
  { href: "/",          label: "Home" },
  { href: "/search",    label: "Search" },
  { href: "/sections",  label: "Sections" },
  { href: "/pricing",   label: "Pricing" },
  { href: "/about",     label: "About" },
];
const path = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- ─────────────── Navbar ─────────────── -->
    <header class="sticky top-0 z-50 border-b border-white/10 bg-ink/80 backdrop-blur-xl">
      <div class="mx-auto flex h-16 max-w-[80rem] items-center px-4 sm:px-6">
        <div class="flex flex-1 justify-start">
          <a href="/" class="shrink-0 font-display text-base font-bold tracking-tight text-mist">
            Lighthouse<span class="text-champagne">.</span>
          </a>
        </div>

        <nav class="hidden md:flex items-center gap-1 text-sm">
          {nav.map((item) => (
            <a
              href={item.href}
              class={[
                "rounded-full px-3 py-1.5 transition no-underline",
                isActive(item.href)
                  ? "bg-white/[0.08] font-semibold text-mist"
                  : "text-mist/65 hover:bg-white/[0.04] hover:text-mist",
              ].join(" ")}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <div class="flex flex-1 items-center justify-end gap-2 text-sm">
          {(() => {
            const pct = Math.min(100, Math.round((usedToday / limit) * 100));
            const danger = pct >= 80;
            const warn = pct >= 50 && pct < 80;
            const barColor = danger ? "bg-coral" : warn ? "bg-champagne" : "bg-mist/60";
            const labelColor = danger ? "text-coral" : warn ? "text-champagne" : "text-mist/75";
            return (
              <a href="/pricing" title={`Daily cap on the ${tier} tier · click to upgrade`}
                 class="hidden sm:flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 text-xs no-underline hover:bg-white/[0.06]">
                <span class={`tabular-nums font-semibold ${labelColor}`}>
                  {usedToday.toLocaleString()}
                </span>
                <span class="text-mist/40">/ {limit.toLocaleString()}</span>
                <span class="block h-1.5 w-12 rounded-full bg-white/10 overflow-hidden">
                  <span class={`block h-full ${barColor} transition-[width]`} style={`width:${pct}%`}></span>
                </span>
                <span class="text-mist/45 uppercase tracking-[0.15em] text-[10px]">{tier}</span>
              </a>
            );
          })()}
          {user ? (
            <>
              {user.is_admin && (
                <a href="/admin" class="rounded-full px-3 py-1.5 text-mist/65 hover:bg-white/[0.04] hover:text-mist no-underline">
                  Admin
                </a>
              )}
              <a href="/home" class="rounded-full px-3 py-1.5 text-mist/80 hover:bg-white/[0.04] no-underline">
                {user.tier === "pro" ? "Pro" : "Reader"}
              </a>
              <a href="/api/auth/logout" class="rounded-full px-3 py-1.5 text-mist/55 hover:text-mist no-underline">
                Sign out
              </a>
            </>
          ) : (
            <a href={`/api/auth/login?return_to=${encodeURIComponent(currentPath)}`}
               class="rounded-full bg-champagne px-4 py-1.5 font-semibold text-ink hover:brightness-110 no-underline">
              Sign in
            </a>
          )}
        </div>
      </div>
    </header>

    <!-- ─────────────── Page heading (optional) ─────────────── -->
    {pageHeading && (
      <div class="mx-auto max-w-[80rem] w-full px-4 sm:px-6 pt-12 pb-2">
        <h1 class="font-display text-4xl md:text-5xl font-extrabold tracking-tight text-mist leading-tight">
          {pageHeading}
        </h1>
        {pageSubhead && (
          <p class="mt-3 text-mist/65 max-w-2xl text-base leading-relaxed">
            {pageSubhead}
          </p>
        )}
      </div>
    )}

    <!-- ─────────────── Slot ─────────────── -->
    {fullBleed ? (
      <main class="flex-1 w-full">
        <slot />
      </main>
    ) : (
      <main class="flex-1 mx-auto max-w-[80rem] w-full px-4 sm:px-6 py-8">
        <slot />
      </main>
    )}

    <!-- ─────────────── Footer ─────────────── -->
    <footer class="mt-16 border-t border-white/10">
      <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-8 flex flex-wrap items-baseline justify-between gap-y-3 text-xs text-mist/55">
        <span>© {new Date().getFullYear()} Harbor Gang. Built in the open.</span>
        <span class="flex flex-wrap gap-x-4 gap-y-1">
          <a href="https://github.com/ElMundiUA/lighthouse" target="_blank" rel="noopener" class="hover:text-champagne">GitHub</a>
          <a href="/mcp/" class="hover:text-champagne">MCP</a>
          <a href="/about" class="hover:text-champagne">About</a>
          <a href="/legal/privacy" class="hover:text-champagne">Privacy</a>
          <a href="/legal/terms" class="hover:text-champagne">Terms</a>
          <a href="/legal/cookies" class="hover:text-champagne">Cookies</a>
        </span>
      </div>
    </footer>
  </body>
</html>
