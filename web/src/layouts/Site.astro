---
// Standard Harbor Gang layout — replaces Newspaper.astro for non-
// archival pages. Compact sticky navbar with backdrop-blur, generous
// whitespace, single Champagne accent, no double-rule borders or
// section flags.

import "@/styles/global.css";
import {
  LIMITS, tierForUser, subjectFor, currentUsage, clientIp,
} from "@/lib/usage";
import { effectiveTier } from "@/lib/users";

interface Props {
  title?: string;
  description?: string;
  pageHeading?: string;
  pageSubhead?: string;
  fullBleed?: boolean;
  ogImage?: string;
  productScope?: "saas" | "engine";
  hideUsagePill?: boolean;
}

const isEngine = Astro.url.pathname.startsWith("/engine");
const inferredScope: "saas" | "engine" = isEngine ? "engine" : "saas";

const {
  productScope = inferredScope,
  hideUsagePill = isEngine,
  title = productScope === "engine"
    ? "Lighthouse Engine — open-source retrieval for grounded coding agents"
    : "Lighthouse — grounding layer for coding agents",
  description = productScope === "engine"
    ? "Lighthouse Engine is the open-source retrieval stack behind Lighthouse. Ingest pipeline, chunker, summariser, BM25 + pgvector, cross-encoder rerank, MCP server. Apache-2.0. Bring your own corpus."
    : "Lighthouse indexes 71K chunks of canonical SDLC reference — RFCs, OWASP, NIST, framework docs — served to coding agents over MCP. Free 200/day, Pro $12/mo.",
  pageHeading,
  pageSubhead,
  fullBleed = false,
  ogImage = productScope === "engine"
    ? "https://lighthouse.harborgang.com/og-engine.png"
    : "https://lighthouse.harborgang.com/og-saas.png",
} = Astro.props;

const user = Astro.locals.user;
const currentPath = Astro.url.pathname + Astro.url.search;

// Resolve tier from the DB on every request (with 30s in-process
// cache) so admin tier-toggle effect is visible without re-login.
// Cookie-tier is stale for cap-comped users.
let tier = tierForUser(user);
try {
  const dbTier = await effectiveTier(user);
  tier = dbTier;
} catch {
  /* keep cookie-tier */
}
const limit = LIMITS[tier];
let usedToday = 0;
try {
  usedToday = await currentUsage(subjectFor(user, clientIp(Astro.request)));
} catch {
  /* keep 0 */
}

const nav = [
  { href: "/pricing",   label: "Pricing" },
  { href: "/engine",    label: "Engine" },
  { href: "/about",     label: "About" },
];
const path = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.toString()} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- ─────────────── Navbar ─────────────── -->
    <header class="sticky top-0 z-50 border-b border-white/10 bg-ink/80 backdrop-blur-xl">
      <div class="mx-auto flex h-16 max-w-[80rem] items-center px-4 sm:px-6">
        <div class="flex flex-1 justify-start">
          <a href={isEngine ? "/engine" : "/"} class="shrink-0 font-display text-base font-bold tracking-tight text-mist">
            {isEngine ? (
              <>Lighthouse<span class="text-mist/55 font-normal ml-1">Engine</span></>
            ) : (
              <>Lighthouse<span class="text-champagne">.</span></>
            )}
          </a>
        </div>

        <nav class="hidden md:flex items-center gap-1 text-sm">
          {nav.map((item) => (
            <a
              href={item.href}
              class={[
                "rounded-full px-3 py-1.5 transition no-underline",
                isActive(item.href)
                  ? "bg-white/[0.08] font-semibold text-mist"
                  : "text-mist/65 hover:bg-white/[0.04] hover:text-mist",
              ].join(" ")}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <div class="flex flex-1 items-center justify-end gap-2 text-sm">
          {!hideUsagePill && (() => {
            const pct = Math.min(100, Math.round((usedToday / limit) * 100));
            const danger = pct >= 80;
            const warn = pct >= 50 && pct < 80;
            const barColor = danger ? "bg-coral" : warn ? "bg-champagne" : "bg-mist/60";
            const labelColor = danger ? "text-coral" : warn ? "text-champagne" : "text-mist/75";
            return (
              <a href="/pricing" title={`Daily cap on the ${tier} tier · click to upgrade`}
                 class="hidden sm:flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 text-xs no-underline hover:bg-white/[0.06]">
                <span class={`tabular-nums font-semibold ${labelColor}`}>
                  {usedToday.toLocaleString()}
                </span>
                <span class="text-mist/40">/ {limit.toLocaleString()}</span>
                <span class="block h-1.5 w-12 rounded-full bg-white/10 overflow-hidden">
                  <span class={`block h-full ${barColor} transition-[width]`} style={`width:${pct}%`}></span>
                </span>
                <span class="text-mist/45 uppercase tracking-[0.15em] text-[10px]">{tier}</span>
              </a>
            );
          })()}
          {user ? (
            <>
              {user.is_admin && (
                <a href="/admin" class="rounded-full px-3 py-1.5 text-mist/65 hover:bg-white/[0.04] hover:text-mist no-underline">
                  Admin
                </a>
              )}
              <a href="/home" class="rounded-full px-3 py-1.5 text-mist/80 hover:bg-white/[0.04] no-underline">
                {user.tier === "pro" ? "Pro" : "Reader"}
              </a>
              <a href="/api/auth/logout" class="rounded-full px-3 py-1.5 text-mist/55 hover:text-mist no-underline">
                Sign out
              </a>
            </>
          ) : isEngine ? (
            <a href="https://github.com/ElMundiUA/lighthouse" target="_blank" rel="noopener"
               class="rounded-full border border-white/15 px-4 py-1.5 font-semibold text-mist hover:border-champagne/40 hover:bg-white/[0.04] no-underline">
              View on GitHub <span aria-hidden="true">↗</span>
            </a>
          ) : (
            <a href={`/api/auth/login?return_to=${encodeURIComponent(currentPath)}`}
               class="rounded-full bg-champagne px-4 py-1.5 font-semibold text-ink hover:brightness-110 no-underline">
              Sign in <span class="hidden md:inline font-normal opacity-75">· free, no card</span>
            </a>
          )}
        </div>
      </div>
    </header>

    <!-- ─────────────── Page heading (optional) ─────────────── -->
    {pageHeading && (
      <div class="mx-auto max-w-[80rem] w-full px-4 sm:px-6 pt-12 pb-2">
        <h1 class="font-display text-4xl md:text-5xl font-extrabold tracking-tight text-mist leading-tight">
          {pageHeading}
        </h1>
        {pageSubhead && (
          <p class="mt-3 text-mist/65 max-w-2xl text-base leading-relaxed">
            {pageSubhead}
          </p>
        )}
      </div>
    )}

    <!-- ─────────────── Slot ─────────────── -->
    {fullBleed ? (
      <main class="flex-1 w-full">
        <slot />
      </main>
    ) : (
      <main class="flex-1 mx-auto max-w-[80rem] w-full px-4 sm:px-6 py-8">
        <slot />
      </main>
    )}

    <!-- ─────────────── Footer ─────────────── -->
    <footer class="mt-16 border-t border-white/10">
      <div class="mx-auto max-w-[80rem] px-4 sm:px-6 py-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-sm">
          <div>
            <p class="section-kicker mb-3">Lighthouse</p>
            <p class="text-mist/45 text-xs mb-3">Hosted SaaS · curated SDLC corpus</p>
            <ul class="space-y-1.5 text-mist/70">
              <li><a href="/" class="hover:text-champagne no-underline">Search the corpus</a></li>
              <li><a href="/pricing" class="hover:text-champagne no-underline">Pricing</a></li>
              <li><a href="/home" class="hover:text-champagne no-underline">MCP quick-start</a></li>
              <li><a href="/about" class="hover:text-champagne no-underline">About</a></li>
            </ul>
          </div>
          <div>
            <p class="section-kicker mb-3">Engine</p>
            <p class="text-mist/45 text-xs mb-3">Open source · Apache-2.0 · BYO corpus</p>
            <ul class="space-y-1.5 text-mist/70">
              <li><a href="/engine" class="hover:text-champagne no-underline">What is Lighthouse Engine</a></li>
              <li><a href="https://github.com/ElMundiUA/lighthouse" target="_blank" rel="noopener" class="hover:text-champagne no-underline">GitHub repo ↗</a></li>
              <li><a href="https://github.com/ElMundiUA/lighthouse#deploy" target="_blank" rel="noopener" class="hover:text-champagne no-underline">Deployment guide ↗</a></li>
              <li><a href="/mcp/" class="hover:text-champagne no-underline">MCP transport</a></li>
            </ul>
          </div>
          <div>
            <p class="section-kicker mb-3">Harbor Gang</p>
            <p class="text-mist/45 text-xs mb-3">Kyiv &amp; remote EU</p>
            <ul class="space-y-1.5 text-mist/70">
              <li><a href="mailto:hello@harborgang.com" class="hover:text-champagne no-underline">hello@harborgang.com</a></li>
              <li><a href="/legal/privacy" class="hover:text-champagne no-underline">Privacy</a></li>
              <li><a href="/legal/terms" class="hover:text-champagne no-underline">Terms</a></li>
              <li><a href="/legal/cookies" class="hover:text-champagne no-underline">Cookies</a></li>
            </ul>
          </div>
        </div>
        <p class="mt-8 pt-6 border-t border-white/5 text-xs text-mist/40">
          © {new Date().getFullYear()} Harbor Gang. Built in the open at
          <a href="https://github.com/ElMundiUA/lighthouse" class="hover:text-champagne">github.com/ElMundiUA/lighthouse</a>.
        </p>
      </div>
    </footer>
  </body>
</html>
